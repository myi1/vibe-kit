#!/usr/bin/env bash
# vibe-retrofit — rescue your messy AI-coded repos.
# See: https://github.com/myi1/vibe-kit
# Bash 3.2+ compatible (Apple stock bash works).

set -eu

# Resolve VIBE_KIT_ROOT: directory containing this script's parent.
# Handles both direct invocation (./bin/vibe-retrofit) and wrapper invocation
# (where install.sh wrote a wrapper that exec's this script with absolute path).
_resolve_self() {
  local src="${BASH_SOURCE[0]}"
  while [ -h "$src" ]; do
    local dir
    dir="$(cd -P "$(dirname "$src")" && pwd)"
    src="$(readlink "$src")"
    case "$src" in
      /*) ;;
      *) src="$dir/$src" ;;
    esac
  done
  echo "$(cd -P "$(dirname "$src")/.." && pwd)"
}
VIBE_KIT_ROOT="${VIBE_KIT_ROOT:-$(_resolve_self)}"

# Single source of truth for version: read the VERSION file at startup.
# Falls back to "unknown" if VERSION is missing (e.g., partial install).
if [ -r "$VIBE_KIT_ROOT/VERSION" ]; then
  VIBE_KIT_VERSION="$(cat "$VIBE_KIT_ROOT/VERSION" | tr -d '[:space:]')"
else
  VIBE_KIT_VERSION="unknown"
fi

# ────────────────────────────────────────────────────────────────────────────
# Helpers
# ────────────────────────────────────────────────────────────────────────────

# Colors (only when stdout is a tty). Bash 3.2 compat: plain assignment, no
# associative arrays.
if [ -t 1 ] && [ "${NO_COLOR:-}" = "" ]; then
  C_RESET="\033[0m"
  C_BOLD="\033[1m"
  C_DIM="\033[2m"
  C_RED="\033[31m"
  C_GREEN="\033[32m"
  C_YELLOW="\033[33m"
  C_BLUE="\033[34m"
  C_CYAN="\033[36m"
else
  C_RESET=""; C_BOLD=""; C_DIM=""; C_RED=""; C_GREEN=""; C_YELLOW=""; C_BLUE=""; C_CYAN=""
fi

_log()   { printf "%b\n" "$*" >&2; }
_info()  { printf "%b%s%b %s\n" "$C_CYAN" "ℹ" "$C_RESET" "$*" >&2; }
_ok()    { printf "%b%s%b %s\n" "$C_GREEN" "✓" "$C_RESET" "$*" >&2; }
_warn()  { printf "%b%s%b %s\n" "$C_YELLOW" "!" "$C_RESET" "$*" >&2; }
_die()   { printf "%b%s%b %s\n" "$C_RED" "✗" "$C_RESET" "$*" >&2; exit 1; }

# Cross-platform SHA-256. Picks shasum (BSD/macOS) or sha256sum (Linux).
# Reads from stdin or file path. Outputs 64-hex-char hash, nothing else.
_SHA256_CMD=""
_resolve_sha256() {
  if command -v shasum >/dev/null 2>&1; then
    _SHA256_CMD="shasum -a 256"
  elif command -v sha256sum >/dev/null 2>&1; then
    _SHA256_CMD="sha256sum"
  else
    _die "Neither 'shasum' nor 'sha256sum' found. Install one (macOS ships shasum, Linux ships sha256sum)."
  fi
}
_sha256() {
  [ -z "$_SHA256_CMD" ] && _resolve_sha256
  if [ -n "${1:-}" ] && [ -f "$1" ]; then
    $_SHA256_CMD < "$1" | awk '{print $1}'
  else
    $_SHA256_CMD | awk '{print $1}'
  fi
}

_check_git_repo() {
  git rev-parse --is-inside-work-tree >/dev/null 2>&1 \
    || _die "Not inside a git repository. Run from your project root."
}

# Refuse to proceed if any tracked target file has uncommitted changes.
# Args: list of paths to check. Skips paths that don't exist.
_check_clean_targets() {
  local dirty=""
  local p
  for p in "$@"; do
    [ -e "$p" ] || continue
    if ! git diff --quiet -- "$p" 2>/dev/null \
       || ! git diff --cached --quiet -- "$p" 2>/dev/null; then
      dirty="$dirty $p"
    fi
  done
  if [ -n "$dirty" ]; then
    _die "Uncommitted changes in:$dirty
Commit or stash these first. vibe-retrofit refuses to interleave with in-progress edits."
  fi
}

_check_command() {
  command -v "$1" >/dev/null 2>&1 \
    || _die "Required command '$1' not found. Install it and retry."
}

# Discovery report paths. Override with --report-path for non-personal repos.
_report_md_path()   { echo "${REPORT_PATH_OVERRIDE:-$PWD}/.vibe-kit-discovery.md"; }
_report_json_path() { echo "${REPORT_PATH_OVERRIDE:-$PWD}/.vibe-kit-discovery.json"; }
_classification_path() { echo "${REPORT_PATH_OVERRIDE:-$PWD}/.vibe-kit-classification.json"; }

# v0.2.0: project_key resolution + global reference dir.
#
# The reference layer (gstack-learnings, design docs, ceo plans, handoffs) lives
# OUTSIDE the repo at ~/.vibe-kit/projects/<project_key>/reference/ so it's
# available to every session regardless of which branch is checked out. The
# v0.1 design put these in docs/vibe-kit/reference/ which broke the moment a
# fresh session opened on a branch that hadn't merged the retrofit yet.
#
# project_key defaults to basename(cwd). User can override by editing
# .vibe-kit-version's project_key field after retrofit (e.g., for repos with
# generic names like "frontend" that collide across projects).
_resolve_project_key() {
  if [ -f .vibe-kit-version ] && command -v jq >/dev/null 2>&1; then
    local stored
    stored="$(jq -r '.project_key // ""' .vibe-kit-version 2>/dev/null)"
    if [ -n "$stored" ] && [ "$stored" != "null" ]; then
      echo "$stored"
      return 0
    fi
  fi
  basename "$(pwd)"
}

_global_project_dir() {
  local key="${1:-$(_resolve_project_key)}"
  echo "$HOME/.vibe-kit/projects/$key"
}

_global_reference_dir() {
  echo "$(_global_project_dir "$@")/reference"
}

# ────────────────────────────────────────────────────────────────────────────
# cmd: discover
# ────────────────────────────────────────────────────────────────────────────
cmd_discover() {
  _check_git_repo

  local md_path; md_path="$(_report_md_path)"
  local json_path; json_path="$(_report_json_path)"

  _info "Running discovery on $(basename "$(pwd)")…"

  # 1. Existing agent-context files.
  # Hardcoded list of well-known formats + heuristic for capitalized root-level
  # .md files that are NOT standard project docs (README, LICENSE, etc.) — those
  # are usually project-specific process docs the user wrote for their agents
  # (e.g., BRAIN.md, DECISION_LOG.md, TASK_QUEUE.md, SOURCE_OF_TRUTH.md). Skill
  # gets to classify them later; discover just surfaces them.
  local agent_files=""
  local f
  for f in CLAUDE.md AGENTS.md .cursorrules .windsurfrules .clinerules ai-instructions.md; do
    [ -f "$f" ] && agent_files="$agent_files $f"
  done
  # Heuristic: ROOT-level capitalized .md (e.g., BRAIN.md, DECISION_LOG.md) that
  # isn't a standard project doc. Excludes README/CHANGELOG/LICENSE/CONTRIBUTING/
  # CODE_OF_CONDUCT/SECURITY/AUTHORS/MAINTAINERS/NOTICE/INSTALL/SUPPORT/GOVERNANCE.
  if git ls-files >/dev/null 2>&1; then
    local heuristic_md
    heuristic_md="$(git ls-files -- '*.md' 2>/dev/null \
      | grep -vE '/' \
      | grep -E '^[A-Z][A-Z0-9_]*\.md$' \
      | grep -vE '^(README|CHANGELOG|LICENSE|CONTRIBUTING|CODE_OF_CONDUCT|SECURITY|AUTHORS|MAINTAINERS|NOTICE|INSTALL|SUPPORT|GOVERNANCE|HISTORY|UPGRADE|UPGRADING|TROUBLESHOOTING|FAQ|TODO|TODOS|BACKLOG|WHATS_NEW|RELEASE_NOTES)\.md$' \
      || true)"
    local hf
    for hf in $heuristic_md; do
      # Only add if not already in the hardcoded list (avoid dupes)
      case " $agent_files " in
        *" $hf "*) ;;
        *) agent_files="$agent_files $hf" ;;
      esac
    done
  fi

  # 2. Existing plan/spec docs (glob via git ls-files for .gitignore respect)
  local plan_docs=""
  if git ls-files >/dev/null 2>&1; then
    plan_docs="$(git ls-files -- \
      'docs/**/*.md' 'docs/*.md' \
      'plans/**/*.md' 'plans/*.md' \
      'specs/**/*.md' 'specs/*.md' \
      'thoughts/**/*.md' 'thoughts/*.md' \
      'design/**/*.md' 'design/*.md' \
      2>/dev/null | grep -vE '^(README|CHANGELOG|LICENSE|CODE_OF_CONDUCT|CONTRIBUTING)\.md$' || true)"
    # Also catch root-level Markdown that isn't standard
    local root_md
    root_md="$(git ls-files -- '*.md' 2>/dev/null \
      | grep -vE '/' \
      | grep -vE '^(README|CHANGELOG|LICENSE|CODE_OF_CONDUCT|CONTRIBUTING)\.md$' || true)"
    if [ -n "$root_md" ]; then
      plan_docs="$plan_docs
$root_md"
    fi
  fi

  # 3. TODO scatter via git grep (respects .gitignore). Includes web template
  # formats (.html/.erb/.vue/.svelte/.astro) for legacy/migration repos.
  # Truncate each match to 200 chars (defends against minified single-line
  # HTML files where one match emits an entire file's worth of content) and
  # cap total stored matches to 200 (anything beyond is noise for the human
  # report and risks argv-too-large when passed to jq).
  local todo_raw=""
  local TODO_MAX_MATCHES=200
  local TODO_MAX_LINE=200
  todo_raw="$(git grep -n -E 'TODO|FIXME|XXX|HACK' -- \
    '*.ts' '*.tsx' '*.js' '*.jsx' '*.mjs' '*.cjs' \
    '*.py' '*.rs' '*.go' '*.rb' '*.java' '*.kt' '*.swift' '*.c' '*.h' '*.cpp' '*.hpp' '*.cs' \
    '*.md' '*.sh' '*.bash' '*.zsh' \
    '*.html' '*.htm' '*.erb' '*.vue' '*.svelte' '*.astro' \
    2>/dev/null | head -"$TODO_MAX_MATCHES" | awk -v max="$TODO_MAX_LINE" '
      { if (length($0) > max) print substr($0, 1, max) " …[truncated]"
        else print }' \
    || true)"
  local todo_count
  todo_count="$(printf '%s' "$todo_raw" | grep -c . || true)"

  # 4. Third-party imports — find the deepest reasonable manifest, not just
  # repo root. Monorepos commonly nest the app under apps/<name>/ or packages/
  # <name>/. Prefer root manifest if it exists; otherwise pick the first one
  # found via git ls-files. NOTE: only one manifest is read per discovery —
  # multi-package monorepos surface as the first app's view.
  local manifest=""
  for mf in package.json requirements.txt pyproject.toml go.mod Cargo.toml Gemfile; do
    if [ -f "$mf" ]; then
      manifest="$mf"
      break
    fi
  done
  if [ -z "$manifest" ] && git ls-files >/dev/null 2>&1; then
    # Find nested manifest. Prefer apps/*/ then packages/*/ paths if present,
    # otherwise alphabetical first.
    manifest="$(git ls-files 2>/dev/null \
      | grep -E '(^|/)(package\.json|requirements\.txt|pyproject\.toml|go\.mod|Cargo\.toml|Gemfile)$' \
      | grep -vE '/(node_modules|vendor|\.venv)/' \
      | awk '{
          # Sort key: apps/* first, then packages/*, then shorter paths
          n = split($0, parts, "/")
          prio = 9
          if (parts[1] == "apps") prio = 1
          else if (parts[1] == "packages") prio = 2
          else prio = 3 + n
          print prio "\t" $0
        }' | sort -n | head -1 | cut -f2)"
  fi

  local libs=""
  case "$(basename "${manifest:-}")" in
    package.json)
      if command -v jq >/dev/null 2>&1; then
        libs="$(jq -r '(.dependencies // {}) + (.devDependencies // {}) | keys[]?' "$manifest" 2>/dev/null | head -20 || true)"
      fi ;;
    requirements.txt)
      libs="$(grep -v '^#' "$manifest" 2>/dev/null | sed -E 's/[<>=!~].*//' | head -20 || true)" ;;
    pyproject.toml)
      libs="$(grep -E '^[a-zA-Z0-9_-]+\s*=' "$manifest" 2>/dev/null | head -20 | awk '{print $1}' || true)" ;;
    go.mod)
      libs="$(awk '/^require/,/^\)/ {print $1}' "$manifest" 2>/dev/null | grep -v 'require\|^)' | head -20 || true)" ;;
    Cargo.toml)
      libs="$(awk '/^\[dependencies\]/,/^\[/' "$manifest" 2>/dev/null | grep '=' | awk -F'=' '{print $1}' | tr -d ' "' | head -20 || true)" ;;
    Gemfile)
      libs="$(grep '^gem ' "$manifest" 2>/dev/null | awk '{print $2}' | tr -d "'\"," | head -20 || true)" ;;
  esac

  # 5. Inferred commands — same manifest as libraries (so a monorepo with
  # apps/hub/package.json picks up its `dev`/`test`/`typecheck` scripts).
  local cmd_test="" cmd_typecheck="" cmd_dev="" cmd_install=""
  local manifest_dir=""
  [ -n "$manifest" ] && manifest_dir="$(dirname "$manifest")"
  if [ "$(basename "${manifest:-}")" = "package.json" ] && command -v jq >/dev/null 2>&1; then
    cmd_test="$(jq -r '.scripts.test // empty' "$manifest" 2>/dev/null)"
    cmd_typecheck="$(jq -r '.scripts.typecheck // .scripts["type-check"] // empty' "$manifest" 2>/dev/null)"
    cmd_dev="$(jq -r '.scripts.dev // .scripts.start // empty' "$manifest" 2>/dev/null)"
    cmd_install="npm install"
    # Lockfile detection uses manifest_dir
    [ -n "$manifest_dir" ] && [ -f "$manifest_dir/yarn.lock" ] && cmd_install="yarn"
    [ -n "$manifest_dir" ] && [ -f "$manifest_dir/pnpm-lock.yaml" ] && cmd_install="pnpm install"
    [ -n "$manifest_dir" ] && { [ -f "$manifest_dir/bun.lockb" ] || [ -f "$manifest_dir/bun.lock" ]; } && cmd_install="bun install"
    # If manifest isn't at root, prefix commands with cd-to-dir hint
    if [ -n "$manifest_dir" ] && [ "$manifest_dir" != "." ]; then
      [ -n "$cmd_test" ] && cmd_test="(cd $manifest_dir && $cmd_test)"
      [ -n "$cmd_typecheck" ] && cmd_typecheck="(cd $manifest_dir && $cmd_typecheck)"
      [ -n "$cmd_dev" ] && cmd_dev="(cd $manifest_dir && $cmd_dev)"
      cmd_install="(cd $manifest_dir && $cmd_install)"
    fi
  fi
  [ -z "$cmd_test" ] && [ -f Makefile ] && grep -qE '^test:' Makefile && cmd_test="make test"
  [ -z "$cmd_test" ] && [ -f pytest.ini -o -f pyproject.toml ] && cmd_test="pytest"
  [ -z "$cmd_test" ] && [ -f Gemfile ] && cmd_test="bundle exec rspec"
  [ -z "$cmd_test" ] && [ -f go.mod ] && cmd_test="go test ./..."
  [ -z "$cmd_test" ] && [ -f Cargo.toml ] && cmd_test="cargo test"

  # 6. Existing Taskmaster state
  local has_taskmaster="no"
  [ -d .taskmaster ] && has_taskmaster="yes"
  local has_todos_md="no"
  [ -f TODOS.md ] || [ -f TODO.md ] || [ -f BACKLOG.md ] && has_todos_md="yes"

  # 7. gstack artifacts. Resolves both the current slug (via gstack-slug, which
  # parses git remote → "owner-repo") AND the legacy basename slug (older
  # gstack versions stored under just the repo name). Catalogs files by type
  # at the project dir + standard subdirectories (ceo-plans/, checkpoints/).
  # All output paths in the JSON are ABSOLUTE so the skill / scaffold step can
  # read or symlink them directly.
  local gstack_home="${GSTACK_HOME:-$HOME/.gstack}"
  local slug_current=""
  local slug_basename
  slug_basename="$(basename "$PWD" | tr -cd 'a-zA-Z0-9._-')"
  if [ -x "$HOME/.claude/skills/gstack/bin/gstack-slug" ]; then
    # gstack-slug writes a cache file via mkdir+mv inside a subshell; tolerate
    # any failure (we just need SLUG=...).
    local _slug_out
    _slug_out="$("$HOME/.claude/skills/gstack/bin/gstack-slug" 2>/dev/null || true)"
    slug_current="$(printf '%s' "$_slug_out" | grep '^SLUG=' | head -1 | cut -d= -f2 | tr -cd 'a-zA-Z0-9._-')"
  fi

  local gstack_paths=""
  local s p
  for s in "$slug_current" "$slug_basename"; do
    [ -z "$s" ] && continue
    p="$gstack_home/projects/$s"
    [ -d "$p" ] || continue
    case " $gstack_paths " in *" $p "*) ;; *) gstack_paths="$gstack_paths $p" ;; esac
  done

  local g_designs="" g_test_plans="" g_ceo_plans="" g_checkpoints=""
  local g_handoffs="" g_autoplans="" g_other_md=""
  local g_reviews_count=0 g_learnings_count=0 g_timeline_count=0 g_deploys_count=0
  for p in $gstack_paths; do
    local _files
    # Root-level .md classified by name pattern
    _files="$(find "$p" -maxdepth 1 -name '*-design-*.md' -type f 2>/dev/null || true)"
    [ -n "$_files" ] && g_designs="${g_designs:+$g_designs
}$_files"
    _files="$(find "$p" -maxdepth 1 -name '*-eng-review-test-plan-*.md' -type f 2>/dev/null || true)"
    [ -n "$_files" ] && g_test_plans="${g_test_plans:+$g_test_plans
}$_files"
    _files="$(find "$p" -maxdepth 1 -name '*-autoplan-*.md' -type f 2>/dev/null || true)"
    [ -n "$_files" ] && g_autoplans="${g_autoplans:+$g_autoplans
}$_files"
    _files="$(find "$p" -maxdepth 1 -name 'handoff*.md' -type f 2>/dev/null || true)"
    [ -n "$_files" ] && g_handoffs="${g_handoffs:+$g_handoffs
}$_files"
    # Subdirectories
    _files="$(find "$p/ceo-plans" -maxdepth 1 -name '*.md' -type f 2>/dev/null || true)"
    [ -n "$_files" ] && g_ceo_plans="${g_ceo_plans:+$g_ceo_plans
}$_files"
    _files="$(find "$p/checkpoints" -maxdepth 1 -name '*.md' -type f 2>/dev/null || true)"
    [ -n "$_files" ] && g_checkpoints="${g_checkpoints:+$g_checkpoints
}$_files"
    # Counts
    if [ -f "$p/learnings.jsonl" ]; then
      g_learnings_count=$(( g_learnings_count + $(wc -l < "$p/learnings.jsonl" 2>/dev/null | tr -d ' ' || echo 0) ))
    fi
    if [ -f "$p/timeline.jsonl" ]; then
      g_timeline_count=$(( g_timeline_count + $(wc -l < "$p/timeline.jsonl" 2>/dev/null | tr -d ' ' || echo 0) ))
    fi
    if [ -f "$p/deploys.jsonl" ]; then
      g_deploys_count=$(( g_deploys_count + $(wc -l < "$p/deploys.jsonl" 2>/dev/null | tr -d ' ' || echo 0) ))
    fi
    g_reviews_count=$(( g_reviews_count + $(find "$p" -maxdepth 1 -name '*-reviews.jsonl' -type f 2>/dev/null | wc -l | tr -d ' ') ))
  done

  # ── Build JSON report (machine-readable for the skill) ──────────────────
  # Build a JSON document with jq for safety. Convert newline-separated lists
  # to JSON arrays.
  local _jq_input
  _jq_input="$(jq -n \
    --arg ver "$VIBE_KIT_VERSION" \
    --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    --arg cwd "$PWD" \
    --arg agent_files "$agent_files" \
    --arg plan_docs "$plan_docs" \
    --arg libs "$libs" \
    --arg todo_count "$todo_count" \
    --arg cmd_test "$cmd_test" \
    --arg cmd_typecheck "$cmd_typecheck" \
    --arg cmd_dev "$cmd_dev" \
    --arg cmd_install "$cmd_install" \
    --arg has_taskmaster "$has_taskmaster" \
    --arg has_todos_md "$has_todos_md" \
    --arg todo_raw "$todo_raw" \
    --arg gstack_paths "$gstack_paths" \
    --arg gstack_slug_current "$slug_current" \
    --arg gstack_slug_basename "$slug_basename" \
    --arg g_designs "$g_designs" \
    --arg g_test_plans "$g_test_plans" \
    --arg g_ceo_plans "$g_ceo_plans" \
    --arg g_checkpoints "$g_checkpoints" \
    --arg g_handoffs "$g_handoffs" \
    --arg g_autoplans "$g_autoplans" \
    --argjson g_reviews_count "$g_reviews_count" \
    --argjson g_learnings_count "$g_learnings_count" \
    --argjson g_timeline_count "$g_timeline_count" \
    --argjson g_deploys_count "$g_deploys_count" \
    '{
      vibe_kit_version: $ver,
      generated_at: $ts,
      project_dir: $cwd,
      agent_context_files: ($agent_files | split(" ") | map(select(length > 0))),
      plan_docs: ($plan_docs | split("\n") | map(select(length > 0))),
      libraries: ($libs | split("\n") | map(select(length > 0))),
      todo_count: ($todo_count | tonumber? // 0),
      todos: ($todo_raw | split("\n") | map(select(length > 0))),
      commands: {
        install: $cmd_install,
        test: $cmd_test,
        typecheck: $cmd_typecheck,
        dev: $cmd_dev
      },
      existing_state: {
        taskmaster: $has_taskmaster,
        todos_md: $has_todos_md
      },
      gstack: {
        slug_current: $gstack_slug_current,
        slug_basename: $gstack_slug_basename,
        project_dirs: ($gstack_paths | split(" ") | map(select(length > 0))),
        designs: ($g_designs | split("\n") | map(select(length > 0))),
        test_plans: ($g_test_plans | split("\n") | map(select(length > 0))),
        ceo_plans: ($g_ceo_plans | split("\n") | map(select(length > 0))),
        checkpoints: ($g_checkpoints | split("\n") | map(select(length > 0))),
        handoffs: ($g_handoffs | split("\n") | map(select(length > 0))),
        autoplans: ($g_autoplans | split("\n") | map(select(length > 0))),
        reviews_jsonl_count: $g_reviews_count,
        learnings_count: $g_learnings_count,
        timeline_count: $g_timeline_count,
        deploys_count: $g_deploys_count
      }
    }')"

  printf '%s\n' "$_jq_input" > "$json_path"

  # ── Build Markdown report (human-readable) ──────────────────────────────
  {
    echo "# Discovery report — $(basename "$(pwd)")"
    echo ""
    echo "Generated by \`vibe-retrofit discover\` (v${VIBE_KIT_VERSION}) at $(date -u +%Y-%m-%dT%H:%M:%SZ)"
    echo ""
    echo "## Agent-context files found"
    echo ""
    if [ -n "$agent_files" ]; then
      for f in $agent_files; do echo "- \`$f\`"; done
    else
      echo "_None — fresh ground for CLAUDE.md._"
    fi
    echo ""
    echo "## Existing plan / spec docs"
    echo ""
    if [ -n "$plan_docs" ]; then
      printf '%s\n' "$plan_docs" | while IFS= read -r line; do
        [ -n "$line" ] && echo "- \`$line\`"
      done
    else
      echo "_None found in docs/, plans/, specs/, thoughts/, design/, or root._"
    fi
    echo ""
    echo "## TODO scatter ($todo_count matches)"
    echo ""
    if [ "$todo_count" -gt 0 ]; then
      echo '```'
      printf '%s\n' "$todo_raw" | head -50
      if [ "$todo_count" -gt 50 ]; then
        echo "... and $((todo_count - 50)) more"
      fi
      echo '```'
    else
      echo "_No TODO/FIXME/XXX/HACK comments found._"
    fi
    echo ""
    echo "## Detected third-party libraries (top 20)"
    echo ""
    if [ -n "$libs" ]; then
      printf '%s\n' "$libs" | while IFS= read -r lib; do
        [ -n "$lib" ] && echo "- $lib"
      done
    else
      echo "_No package.json / requirements.txt / go.mod / Cargo.toml / Gemfile detected._"
    fi
    echo ""
    echo "## Inferred commands"
    echo ""
    echo "- **Install:** \`${cmd_install:-(not detected)}\`"
    echo "- **Test:** \`${cmd_test:-(not detected)}\`"
    echo "- **Typecheck:** \`${cmd_typecheck:-(not detected)}\`"
    echo "- **Dev server:** \`${cmd_dev:-(not detected)}\`"
    echo ""
    echo "## Existing task-tracking state"
    echo ""
    echo "- Taskmaster initialized: **$has_taskmaster**"
    echo "- TODOS.md / TODO.md / BACKLOG.md present: **$has_todos_md**"
    echo ""
    echo "## gstack history"
    echo ""
    if [ -n "$gstack_paths" ]; then
      echo "Found existing gstack artifacts for this repo. **This is the load-bearing scattered context you've been writing over the past sessions** — design docs from /office-hours, CEO plans, eng-review test plans, checkpoints, handoff notes, structured learnings, session timeline. The retrofit will symlink the most useful ones under \`docs/vibe-kit/reference/\` and convert \`learnings.jsonl\` to a human-readable index."
      echo ""
      echo "- **Slug(s) checked:** \`${slug_current:-(none)}\` (current) + \`${slug_basename}\` (legacy basename)"
      echo "- **Project dirs found:**"
      for p in $gstack_paths; do echo "  - \`$p\`"; done
      echo ""
      local _d_count=0 _t_count=0 _c_count=0 _ck_count=0 _h_count=0 _a_count=0
      [ -n "$g_designs" ] && _d_count="$(printf '%s' "$g_designs" | grep -c . || echo 0)"
      [ -n "$g_test_plans" ] && _t_count="$(printf '%s' "$g_test_plans" | grep -c . || echo 0)"
      [ -n "$g_ceo_plans" ] && _c_count="$(printf '%s' "$g_ceo_plans" | grep -c . || echo 0)"
      [ -n "$g_checkpoints" ] && _ck_count="$(printf '%s' "$g_checkpoints" | grep -c . || echo 0)"
      [ -n "$g_handoffs" ] && _h_count="$(printf '%s' "$g_handoffs" | grep -c . || echo 0)"
      [ -n "$g_autoplans" ] && _a_count="$(printf '%s' "$g_autoplans" | grep -c . || echo 0)"
      echo "**Counts:**"
      echo "- Design docs (\`*-design-*.md\`): **$_d_count**"
      echo "- Eng-review test plans (\`*-eng-review-test-plan-*.md\`): **$_t_count**"
      echo "- CEO plans (\`ceo-plans/*.md\`): **$_c_count**"
      echo "- Checkpoints (\`checkpoints/*.md\`): **$_ck_count**"
      echo "- Handoff notes (\`handoff*.md\`): **$_h_count**"
      echo "- Autoplan snapshots (\`*-autoplan-*.md\`): **$_a_count**"
      echo "- Reviews JSONL files (\`*-reviews.jsonl\`): **$g_reviews_count**"
      echo "- Learnings entries (\`learnings.jsonl\` lines): **$g_learnings_count**"
      echo "- Timeline entries (\`timeline.jsonl\` lines): **$g_timeline_count**"
      echo "- Deploys logged (\`deploys.jsonl\` lines): **$g_deploys_count**"
      echo ""
      # List a few sample paths so user can read directly
      if [ "$_d_count" -gt 0 ]; then
        echo "**Recent design docs (sample):**"
        printf '%s\n' "$g_designs" | sort -r | head -5 | while IFS= read -r f; do
          [ -n "$f" ] && echo "- \`$f\`"
        done
        echo ""
      fi
      if [ "$_c_count" -gt 0 ]; then
        echo "**CEO plans:**"
        printf '%s\n' "$g_ceo_plans" | sort -r | head -5 | while IFS= read -r f; do
          [ -n "$f" ] && echo "- \`$f\`"
        done
        echo ""
      fi
      if [ "$_h_count" -gt 0 ]; then
        echo "**Recent handoff notes:**"
        printf '%s\n' "$g_handoffs" | sort -r | head -3 | while IFS= read -r f; do
          [ -n "$f" ] && echo "- \`$f\`"
        done
        echo ""
      fi
    else
      echo "_No gstack artifacts found at \`$gstack_home/projects/${slug_current:-?}\` or \`$gstack_home/projects/${slug_basename}\`. This is either a brand-new repo or one you've never run gstack skills against._"
      echo ""
    fi
    echo "---"
    echo ""
    echo "_Read this report before running \`vibe-retrofit tier 1/2/3\`. It is the input that distinguishes a smart retrofit from a dumb one._"
  } > "$md_path"

  # ── Colored stdout summary (the user's "I read this" moment) ────────────
  # Pre-compute counts so we don't rely on `grep -c . || echo 0` (which prints
  # 0 twice when the input is empty: once from grep, once from echo).
  local _agent_count _plan_count _lib_count
  _agent_count=$(echo "$agent_files" | tr ' ' '\n' | grep -c . 2>/dev/null || true)
  [ -z "$_agent_count" ] && _agent_count=0
  _plan_count=$(printf '%s' "$plan_docs" | grep -c . 2>/dev/null || true)
  [ -z "$_plan_count" ] && _plan_count=0
  _lib_count=$(printf '%s' "$libs" | grep -c . 2>/dev/null || true)
  [ -z "$_lib_count" ] && _lib_count=0

  printf "\n"
  printf "%b┌─ Discovery summary ──────────────────────────────────────┐%b\n" "$C_BOLD" "$C_RESET"
  printf "  %bProject:%b   %s\n" "$C_DIM" "$C_RESET" "$(basename "$(pwd)")"
  printf "  %bAgent files:%b %s%s%b\n" "$C_DIM" "$C_RESET" "$C_CYAN" "$_agent_count" "$C_RESET"
  printf "  %bPlan docs:%b %s%s%b\n"   "$C_DIM" "$C_RESET" "$C_CYAN" "$_plan_count"  "$C_RESET"
  printf "  %bTODOs:%b     %s%s%b\n"   "$C_DIM" "$C_RESET" "$C_YELLOW" "$todo_count" "$C_RESET"
  printf "  %bLibraries:%b %s%s%b\n"   "$C_DIM" "$C_RESET" "$C_CYAN" "$_lib_count"   "$C_RESET"
  printf "  %bTaskmaster:%b %s%s%b   %bTODOS.md:%b %s%s%b\n" "$C_DIM" "$C_RESET" \
    "$(if [ "$has_taskmaster" = "yes" ]; then echo "$C_GREEN"; else echo "$C_DIM"; fi)" "$has_taskmaster" "$C_RESET" \
    "$C_DIM" "$C_RESET" \
    "$(if [ "$has_todos_md" = "yes" ]; then echo "$C_GREEN"; else echo "$C_DIM"; fi)" "$has_todos_md" "$C_RESET"
  # gstack history row (only when found)
  if [ -n "$gstack_paths" ]; then
    local _gs_total=0
    _gs_total=$(( $(printf '%s' "$g_designs" | grep -c . || true) + \
                  $(printf '%s' "$g_test_plans" | grep -c . || true) + \
                  $(printf '%s' "$g_ceo_plans" | grep -c . || true) + \
                  $(printf '%s' "$g_checkpoints" | grep -c . || true) + \
                  $(printf '%s' "$g_handoffs" | grep -c . || true) + \
                  $(printf '%s' "$g_autoplans" | grep -c . || true) ))
    printf "  %bgstack:%b    %s%s%b artifacts  (learnings=%s, timeline=%s, deploys=%s)\n" \
      "$C_DIM" "$C_RESET" "$C_GREEN" "$_gs_total" "$C_RESET" \
      "$g_learnings_count" "$g_timeline_count" "$g_deploys_count"
  fi
  printf "%b└──────────────────────────────────────────────────────────┘%b\n\n" "$C_BOLD" "$C_RESET"

  _ok "Wrote $md_path"
  _ok "Wrote $json_path"
  _info "Read the markdown report. Then run \`vibe-retrofit tier 1\` (or tier 2 / tier 3)."
}

# ────────────────────────────────────────────────────────────────────────────
# cmd: merge-claude-md
# Append-only delimited block update. Honors --dry-run, --force.
# Reads classification from .vibe-kit-classification.json (if skill ran);
# otherwise uses the raw template with discovery commands substituted.
# ────────────────────────────────────────────────────────────────────────────
cmd_merge_claude_md() {
  _check_git_repo
  local dry_run=0 force=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --dry-run) dry_run=1 ;;
      --force)   force=1 ;;
      *) _die "Unknown flag for merge-claude-md: $1" ;;
    esac
    shift
  done

  local tmpl="$VIBE_KIT_ROOT/templates/CLAUDE.md.tmpl"
  [ -f "$tmpl" ] || _die "Template not found: $tmpl"

  [ "$dry_run" -eq 0 ] && _check_clean_targets CLAUDE.md

  local json_path; json_path="$(_report_json_path)"
  [ -f "$json_path" ] || _die "No discovery report at $json_path. Run 'vibe-retrofit discover' first."

  # Pull inferred commands from the discovery JSON. jq's `//` operator only
  # fires on null, NOT on empty strings — and discover writes empty strings
  # when nothing is inferred. Treat both as "not detected" explicitly.
  local cmd_test cmd_typecheck cmd_dev cmd_install
  local _missing='(not detected — fill in)'
  cmd_test="$(jq -r --arg m "$_missing" '.commands.test | if . == null or . == "" then $m else . end' "$json_path")"
  cmd_typecheck="$(jq -r --arg m "$_missing" '.commands.typecheck | if . == null or . == "" then $m else . end' "$json_path")"
  cmd_dev="$(jq -r --arg m "$_missing" '.commands.dev | if . == null or . == "" then $m else . end' "$json_path")"
  cmd_install="$(jq -r --arg m "$_missing" '.commands.install | if . == null or . == "" then $m else . end' "$json_path")"

  # Build context7 library allowlist
  local libs_block
  libs_block="$(jq -r '.libraries | if length == 0 then "_No third-party libraries detected._" else map("- " + .) | join("\n") end' "$json_path")"

  # v0.2.0: resolve project_key + the global reference dir so the rendered
  # CLAUDE.md block points at the canonical out-of-repo location instead of
  # a docs/vibe-kit/reference/ that may not exist on the current branch.
  local project_key global_ref
  project_key="$(_resolve_project_key)"
  global_ref="$(_global_reference_dir "$project_key")"
  # Render with $HOME contracted to ~ for display readability.
  local global_ref_display
  global_ref_display="${global_ref/#$HOME/~}"

  # Render the template by simple variable substitution.
  # Bash 3.2 compat: use sed -e for each variable.
  local rendered
  rendered="$(cat "$tmpl")"
  rendered="${rendered//\{\{retrofitted_at\}\}/$(date -u +%Y-%m-%dT%H:%M:%SZ)}"
  rendered="${rendered//\{\{install_command\}\}/$cmd_install}"
  rendered="${rendered//\{\{test_command\}\}/$cmd_test}"
  rendered="${rendered//\{\{typecheck_command\}\}/$cmd_typecheck}"
  rendered="${rendered//\{\{dev_server_command\}\}/$cmd_dev}"
  rendered="${rendered//\{\{project_key\}\}/$project_key}"
  rendered="${rendered//\{\{global_reference_dir\}\}/$global_ref_display}"

  # Detect existing marker block in CLAUDE.md
  local start_marker="<!-- vibe-kit-retrofit:v0.1 "
  local end_marker="<!-- /vibe-kit-retrofit:v0.1 -->"

  local has_block=0
  if [ -f CLAUDE.md ] && grep -qF "$start_marker" CLAUDE.md 2>/dev/null; then
    has_block=1
  fi

  if [ "$has_block" -eq 1 ] && [ "$force" -eq 0 ]; then
    # Check block hash against .vibe-kit-version (if present)
    if [ -f .vibe-kit-version ] && command -v jq >/dev/null 2>&1; then
      local stored_hash
      stored_hash="$(jq -r '.claude_md_block_hash // ""' .vibe-kit-version 2>/dev/null)"
      if [ -n "$stored_hash" ]; then
        local current_block
        current_block="$(awk -v start="$start_marker" -v end="$end_marker" '
          index($0, start) {p=1}
          p {print}
          index($0, end) {exit}
        ' CLAUDE.md)"
        local current_hash
        current_hash="$(printf '%s' "$current_block" | _sha256)"
        if [ "$current_hash" != "$stored_hash" ]; then
          _die "Block hash mismatch — you've edited the vibe-kit block in CLAUDE.md.
Run with --force to overwrite, or move your custom edits ABOVE the marker block.
  Stored hash:  $stored_hash
  Current hash: $current_hash"
        fi
      fi
    fi
  fi

  if [ "$dry_run" -eq 1 ]; then
    _info "DRY RUN: would update CLAUDE.md as follows:"
    if [ "$has_block" -eq 1 ]; then
      _info "  → replace existing marker block (preserving content above + below)"
    else
      _info "  → append marker block at end of file"
    fi
    printf "\n%b--- preview of new block ---%b\n" "$C_DIM" "$C_RESET"
    printf '%s\n' "$rendered" | head -30
    printf "%b... (full block is %s lines)%b\n" "$C_DIM" "$(printf '%s' "$rendered" | wc -l)" "$C_RESET"
    return 0
  fi

  if [ "$has_block" -eq 1 ]; then
    # Replace the existing block. awk's -v doesn't support multi-line values,
    # so write the new block to a tempfile and have awk read it inline.
    local tmpfile new_block_file
    tmpfile="$(mktemp)"
    new_block_file="$(mktemp)"
    printf '%s\n' "$rendered" > "$new_block_file"
    awk -v start="$start_marker" -v end="$end_marker" -v new_block_file="$new_block_file" '
      BEGIN { in_block=0; printed_new=0 }
      index($0, start) {
        if (!printed_new) {
          while ((getline line < new_block_file) > 0) print line
          close(new_block_file)
          printed_new=1
        }
        in_block=1
        next
      }
      in_block && index($0, end) {
        in_block=0
        next
      }
      !in_block { print }
    ' CLAUDE.md > "$tmpfile"
    mv "$tmpfile" CLAUDE.md
    rm -f "$new_block_file"
    _ok "Replaced existing vibe-kit block in CLAUDE.md."
  elif [ -f CLAUDE.md ]; then
    # Append at end of file.
    {
      echo ""
      printf '%s\n' "$rendered"
    } >> CLAUDE.md
    _ok "Appended vibe-kit block at end of CLAUDE.md."
  else
    # Create from template.
    printf '%s\n' "$rendered" > CLAUDE.md
    _ok "Created CLAUDE.md from template."
  fi
}

# ────────────────────────────────────────────────────────────────────────────
# cmd: write-version
# Writes .vibe-kit-version JSON with template hashes + block hash.
# ────────────────────────────────────────────────────────────────────────────
cmd_write_version() {
  local dry_run=0 tier=1
  while [ $# -gt 0 ]; do
    case "$1" in
      --dry-run) dry_run=1 ;;
      --tier)    shift; tier="$1" ;;
      *) _die "Unknown flag for write-version: $1" ;;
    esac
    shift
  done

  local tmpl_dir="$VIBE_KIT_ROOT/templates"
  local rules_dir="$VIBE_KIT_ROOT/rules"
  local start_marker="<!-- vibe-kit-retrofit:v0.1 "
  local end_marker="<!-- /vibe-kit-retrofit:v0.1 -->"

  # Hash each tracked template + rule file
  local th_claude th_context7 th_taskmaster th_verification
  th_claude="$(_sha256 "$tmpl_dir/CLAUDE.md.tmpl")"
  th_context7="$(_sha256 "$rules_dir/context7.md")"
  th_taskmaster="$(_sha256 "$rules_dir/taskmaster.md")"
  th_verification="$(_sha256 "$rules_dir/verification-checklist.md")"

  # Hash the CLAUDE.md block content (if present)
  local block_hash=""
  if [ -f CLAUDE.md ] && grep -qF "$start_marker" CLAUDE.md 2>/dev/null; then
    local block_content
    block_content="$(awk -v start="$start_marker" -v end="$end_marker" '
      index($0, start) {p=1}
      p {print}
      index($0, end) {exit}
    ' CLAUDE.md)"
    block_hash="$(printf '%s' "$block_content" | _sha256)"
  fi

  # v0.2.0: project_key persists across upgrades. If already set in
  # .vibe-kit-version (e.g., user manually overrode for a collision), preserve
  # it. Otherwise default to basename(cwd).
  local project_key
  project_key="$(_resolve_project_key)"
  local global_dir
  global_dir="$(_global_project_dir "$project_key")"

  local out
  out="$(jq -n \
    --arg ver "$VIBE_KIT_VERSION" \
    --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    --argjson tier "$tier" \
    --arg th_claude "$th_claude" \
    --arg th_context7 "$th_context7" \
    --arg th_taskmaster "$th_taskmaster" \
    --arg th_verification "$th_verification" \
    --arg block_hash "$block_hash" \
    --arg project_key "$project_key" \
    --arg global_dir "$global_dir" \
    '{
      vibe_kit_version: $ver,
      retrofitted_at: $ts,
      tier: $tier,
      project_key: $project_key,
      global_reference_dir: ($global_dir + "/reference"),
      template_hashes: {
        "templates/CLAUDE.md.tmpl": $th_claude,
        "rules/context7.md": $th_context7,
        "rules/taskmaster.md": $th_taskmaster,
        "rules/verification-checklist.md": $th_verification
      },
      claude_md_block_hash: $block_hash
    }')"

  if [ "$dry_run" -eq 1 ]; then
    _info "DRY RUN: would write .vibe-kit-version:"
    printf '%s\n' "$out"
    return 0
  fi

  printf '%s\n' "$out" > .vibe-kit-version
  _ok "Wrote .vibe-kit-version (tier $tier, project_key=$project_key, block_hash=${block_hash:0:8}…)"
}

# ────────────────────────────────────────────────────────────────────────────
# cmd: init-taskmaster
# Tier-3 only. Calls task-master init + parse-prd. Requires API key.
# ────────────────────────────────────────────────────────────────────────────
cmd_init_taskmaster() {
  local dry_run=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --dry-run) dry_run=1 ;;
      *) _die "Unknown flag for init-taskmaster: $1" ;;
    esac
    shift
  done

  _check_command task-master
  _check_command jq

  # API key check
  if [ -z "${OPENAI_API_KEY:-}" ] && [ -z "${ANTHROPIC_API_KEY:-}" ] && [ -z "${PERPLEXITY_API_KEY:-}" ]; then
    _die "No LLM API key in env (OPENAI_API_KEY, ANTHROPIC_API_KEY, or PERPLEXITY_API_KEY).
task-master parse-prd needs one. Set in your shell:
  export OPENAI_API_KEY=...
Then retry."
  fi

  local json_path; json_path="$(_report_json_path)"
  [ -f "$json_path" ] || _die "No discovery report at $json_path. Run 'vibe-retrofit discover' first."

  # Build synthetic PRD from discovered TODOs
  local todo_count
  todo_count="$(jq -r '.todo_count' "$json_path")"
  if [ "$todo_count" = "0" ] || [ "$todo_count" = "null" ]; then
    _warn "No TODOs discovered. Skipping Taskmaster import."
    return 0
  fi

  local prd_file
  prd_file="$(mktemp -t vibe-prd-XXXXXX).md"
  {
    echo "# Discovered work from $(basename "$(pwd)")"
    echo ""
    echo "Generated by \`vibe-retrofit init-taskmaster\` on $(date -u +%Y-%m-%dT%H:%M:%SZ)."
    echo ""
    echo "## Context"
    echo ""
    echo "This PRD lists discovered TODO / FIXME / XXX / HACK comments from the codebase. Each item already represents work that someone (often past-me) flagged as needing attention. Create one task per item, preserve file path provenance, set sensible priority, and DO NOT invent additional tasks not represented here."
    echo ""
    echo "## Tasks discovered"
    echo ""
    jq -r '.todos[] | "- " + .' "$json_path"
  } > "$prd_file"

  local task_count
  task_count="$(jq -r '.todo_count' "$json_path")"

  if [ "$dry_run" -eq 1 ]; then
    _info "DRY RUN: would invoke task-master init + parse-prd."
    _info "Synthetic PRD ($task_count tasks) at: $prd_file"
    printf "\n%b--- PRD preview (first 20 lines) ---%b\n" "$C_DIM" "$C_RESET"
    head -20 "$prd_file"
    printf "%b... %s more lines%b\n" "$C_DIM" "$(($(wc -l < "$prd_file") - 20))" "$C_RESET"
    return 0
  fi

  # Initialize Taskmaster (idempotent — won't overwrite if already initialized)
  if [ ! -d .taskmaster ]; then
    _info "Initializing Taskmaster…"
    task-master init -y >&2
  else
    _info "Taskmaster already initialized — skipping init."
  fi

  # parse-prd produces tasks from the PRD
  _info "Importing $task_count discovered TODOs via task-master parse-prd (estimated cost: ~\$$(awk "BEGIN{printf \"%.4f\", $task_count * 0.0001}"))…"
  task-master parse-prd --input="$prd_file" --num-tasks="$task_count" --force >&2

  rm -f "$prd_file"
  _ok "Taskmaster initialized. Run \`task-master list\` to see imported tasks. Triage stale ones via \`task-master set-status <id> deferred\` or \`task-master remove-task --id=<id>\`."
}

# ────────────────────────────────────────────────────────────────────────────
# cmd: board (v0.10.0)
# Read-only kanban over scattered task surfaces. JSON-first: the aggregator
# (--json) unifies Taskmaster + git PRs + commitments.jsonl + specs into one
# board JSON, consumable by both the bun-serve dashboard AND /vibe-start.
#
# Usage:
#   vibe-retrofit board --json [--repo PATH]   # aggregate, print JSON
#   vibe-retrofit board [--port N] [--open]     # live dashboard via bun serve
# ────────────────────────────────────────────────────────────────────────────

# Pure aggregator. Reads all task surfaces, emits unified board JSON.
_board_aggregate() {
  local repo="${1:-$PWD}"
  cd "$repo" 2>/dev/null || { echo '{"error":"cannot cd to repo","columns":[]}'; return 1; }

  local now; now=$(date +%s)
  local stale_days="${VIBE_KIT_BOARD_STALE_DAYS:-7}"
  local stale_secs=$(( stale_days * 86400 ))
  local repo_name; repo_name=$(basename "$repo")

  # --- helper: age in days from an ISO-8601 timestamp ---
  _iso_age_days() {
    local iso="$1" epoch
    epoch=$(date -j -f "%Y-%m-%dT%H:%M:%SZ" "$iso" +%s 2>/dev/null \
         || date -d "$iso" +%s 2>/dev/null || echo "$now")
    echo $(( (now - epoch) / 86400 ))
  }

  # --- Taskmaster: read tasks.json directly (tolerant of format variants) ---
  local tm_backlog="[]" tm_inflight="[]" tm_landed="[]"
  local tm_file=""
  for cand in .taskmaster/tasks/tasks.json .taskmaster/tasks.json; do
    [ -f "$cand" ] && { tm_file="$cand"; break; }
  done
  if [ -n "$tm_file" ]; then
    # Newer taskmaster nests under .master.tasks; older is top-level .tasks
    local all_tasks
    all_tasks=$(jq -c '(.master.tasks // .tasks // [])' "$tm_file" 2>/dev/null || echo "[]")
    tm_backlog=$(echo "$all_tasks" | jq -c '[.[] | select(.status=="pending") | {title: .title, source: "taskmaster", id: (.id|tostring)}]' 2>/dev/null || echo "[]")
    tm_inflight=$(echo "$all_tasks" | jq -c '[.[] | select(.status=="in-progress" or .status=="in_progress") | {title: .title, source: "taskmaster", id: (.id|tostring)}]' 2>/dev/null || echo "[]")
    tm_landed=$(echo "$all_tasks" | jq -c '[.[] | select(.status=="done") | {title: .title, source: "taskmaster", id: (.id|tostring)}] | .[0:10]' 2>/dev/null || echo "[]")
  fi

  # --- commitments.jsonl (jp-jsonl mode) ---
  local commit_backlog="[]"
  if [ "$(_memory_format_mode 2>/dev/null)" = "jp-jsonl" ]; then
    local mdir; mdir=$(jq -r '.memory_dir // ""' "$HOME/.vibe-kit/config.json" 2>/dev/null)
    if [ -n "$mdir" ] && [ -f "$mdir/commitments.jsonl" ]; then
      # Latest line per `what` wins; keep only status:open
      commit_backlog=$(jq -sc '
        group_by(.what) | map(sort_by(.ts) | last)
        | [.[] | select(.status=="open") | {title: .what, source: "commitment", id: (.what|.[0:24])}]
      ' "$mdir/commitments.jsonl" 2>/dev/null || echo "[]")
    fi
  fi

  # --- git PRs via gh ---
  local pr_review="[]" pr_landed="[]"
  if command -v gh >/dev/null 2>&1 && gh auth status >/dev/null 2>&1; then
    pr_review=$(gh pr list --state open --json number,title,url,isDraft,createdAt 2>/dev/null | jq -c '
      [.[] | {title: .title, source: (if .isDraft then "PR (draft)" else "PR" end), id: (.number|tostring), url: .url}]
    ' 2>/dev/null || echo "[]")
    pr_landed=$(gh pr list --state merged --limit 8 --json number,title,url,mergedAt 2>/dev/null | jq -c '
      [.[] | {title: .title, source: "PR (merged)", id: (.number|tostring), url: .url}]
    ' 2>/dev/null || echo "[]")
  fi

  # --- git branches with unmerged work (in-flight signal) ---
  local branch_inflight="[]"
  if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    local default_branch
    default_branch=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@' || echo "main")
    branch_inflight=$(git for-each-ref --format='%(refname:short)' refs/heads/ 2>/dev/null \
      | grep -vE "^(${default_branch}|main|master)$" \
      | head -10 \
      | jq -Rc '{title: ("branch: " + .), source: "git-branch", id: .}' 2>/dev/null \
      | jq -sc '.' 2>/dev/null || echo "[]")
  fi

  # --- specs + constitution presence ---
  local specs="[]"
  if [ -f docs/vibe-kit/CONSTITUTION.md ]; then
    specs=$(echo "$specs" | jq -c '. + [{title: "CONSTITUTION.md", source: "constitution", id: "constitution"}]')
  fi
  if [ -d docs/vibe-kit/specs ]; then
    local spec_items
    spec_items=$(ls docs/vibe-kit/specs/ 2>/dev/null | head -10 | jq -Rc '{title: ., source: "spec", id: .}' | jq -sc '.' 2>/dev/null || echo "[]")
    specs=$(echo "$specs $spec_items" | jq -sc 'add')
  fi

  # --- assemble columns ---
  jq -n \
    --argjson backlog "$(echo "$tm_backlog $commit_backlog" | jq -sc 'add')" \
    --argjson inflight "$(echo "$tm_inflight $branch_inflight" | jq -sc 'add')" \
    --argjson review "$pr_review" \
    --argjson landed "$(echo "$tm_landed $pr_landed" | jq -sc 'add')" \
    --argjson specs "$specs" \
    --arg repo "$repo_name" \
    --arg generated "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    '{
      repo: $repo,
      generated_at: $generated,
      columns: [
        {name: "Specs & Invariants", items: $specs},
        {name: "Backlog", items: $backlog},
        {name: "In flight", items: $inflight},
        {name: "Pending review", items: $review},
        {name: "Landed", items: $landed}
      ]
    }'
}

cmd_board() {
  local as_json=0 port=4317 do_open=0 repo="$PWD"
  while [ $# -gt 0 ]; do
    case "$1" in
      --json)  as_json=1 ;;
      --port)  shift; port="$1" ;;
      --open)  do_open=1 ;;
      --repo)  shift; repo="$1" ;;
      *) _die "Unknown flag for board: $1" ;;
    esac
    shift
  done

  if [ "$as_json" -eq 1 ]; then
    _board_aggregate "$repo"
    return 0
  fi

  # Live dashboard mode — requires bun
  _check_command bun
  local server="$VIBE_KIT_ROOT/bin/board-server.ts"
  [ -f "$server" ] || _die "Board server not found at $server. Re-run install.sh."
  _info "vibe-kit board → http://localhost:$port  (read-only; Ctrl-C to stop)"
  if [ "$do_open" -eq 1 ]; then
    ( sleep 1; (command -v open >/dev/null 2>&1 && open "http://localhost:$port") \
        || (command -v xdg-open >/dev/null 2>&1 && xdg-open "http://localhost:$port") ) &
  fi
  VIBE_KIT_BOARD_REPO="$repo" VIBE_KIT_ROOT="$VIBE_KIT_ROOT" exec bun run "$server" "$port"
}

# ────────────────────────────────────────────────────────────────────────────
# cmd: memory-format (v0.7.1)
# JP-jsonl integration. Workspace-memory shops opt in via this command;
# .vibe-wrap then writes handoffs as both prose markdown AND structured
# JSONL deltas into the JP-style memory/ tree.
#
# Usage:
#   vibe-retrofit memory-format set jp-jsonl       # interactive opt-in
#   vibe-retrofit memory-format set vibe-kit-markdown   # revert to default
#   vibe-retrofit memory-format status             # show resolved values + source
# ────────────────────────────────────────────────────────────────────────────

# Resolve current memory_format mode (env > global > per-repo > default)
_memory_format_mode() {
  local m
  m="${VIBE_KIT_MEMORY_FORMAT:-}"
  if [ -n "$m" ]; then echo "$m"; return; fi
  if [ -f "$HOME/.vibe-kit/config.json" ]; then
    m=$(jq -r '.memory_format // ""' "$HOME/.vibe-kit/config.json" 2>/dev/null)
    if [ -n "$m" ] && [ "$m" != "null" ] && [ "$m" != "" ]; then echo "$m"; return; fi
  fi
  if [ -f .vibe-kit-version ]; then
    m=$(jq -r '.memory_format // ""' .vibe-kit-version 2>/dev/null)
    if [ -n "$m" ] && [ "$m" != "null" ] && [ "$m" != "" ]; then echo "$m"; return; fi
  fi
  echo "vibe-kit-markdown"
}

cmd_memory_format() {
  local action="${1:-status}"; shift 2>/dev/null || true
  local cfg="$HOME/.vibe-kit/config.json"

  case "$action" in
    set)
      local target="${1:-}"
      [ -z "$target" ] && _die "Usage: vibe-retrofit memory-format set {jp-jsonl|vibe-kit-markdown}"
      case "$target" in
        vibe-kit-markdown)
          mkdir -p "$HOME/.vibe-kit"
          [ -f "$cfg" ] || echo "{}" > "$cfg"
          local tmp; tmp="$(mktemp)"
          jq '. + {memory_format: "vibe-kit-markdown"} | del(.memory_dir, .operator_name, .confidential_paths)' "$cfg" > "$tmp" && mv "$tmp" "$cfg"
          _ok "memory_format = vibe-kit-markdown (default)"
          echo "  /vibe-wrap writes to ~/.vibe-kit/projects/<key>/handoffs/"
          ;;
        jp-jsonl)
          _memory_format_setup_jp_jsonl
          ;;
        *)
          _die "Unknown format '$target'. Valid: jp-jsonl, vibe-kit-markdown"
          ;;
      esac
      ;;
    status)
      local mode; mode="$(_memory_format_mode)"
      echo "memory_format: $mode"
      if [ "$mode" = "jp-jsonl" ]; then
        local md od cp
        md=$(jq -r '.memory_dir // "(unset)"' "$cfg" 2>/dev/null)
        od=$(jq -r '.operator_name // "(unset)"' "$cfg" 2>/dev/null)
        cp=$(jq -r '.confidential_paths // [] | join(", ")' "$cfg" 2>/dev/null)
        echo "  memory_dir:         $md"
        echo "  operator_name:      $od"
        echo "  confidential_paths: $cp"
        if [ "$md" != "(unset)" ] && [ "$md" != "null" ]; then
          if [ -d "$md" ]; then
            echo "  memory_dir status:  exists ✓"
          else
            echo "  memory_dir status:  MISSING (set jp-jsonl will refuse to write there)"
          fi
        fi
      else
        echo "  /vibe-wrap writes to ~/.vibe-kit/projects/<key>/handoffs/"
      fi
      echo ""
      echo "Resolution chain (highest precedence first):"
      echo "  1. \$VIBE_KIT_MEMORY_FORMAT=${VIBE_KIT_MEMORY_FORMAT:-(unset)}"
      if [ -f "$cfg" ]; then
        local g; g=$(jq -r '.memory_format // "(unset)"' "$cfg" 2>/dev/null)
        echo "  2. $cfg memory_format=$g"
      else
        echo "  2. $cfg (file missing)"
      fi
      if [ -f .vibe-kit-version ]; then
        local r; r=$(jq -r '.memory_format // "(unset)"' .vibe-kit-version 2>/dev/null)
        echo "  3. .vibe-kit-version memory_format=$r"
      fi
      echo "  4. built-in default: vibe-kit-markdown"
      ;;
    *)
      _die "Usage: vibe-retrofit memory-format {set <format>|status}"
      ;;
  esac
}

# Interactive setup wizard for jp-jsonl
_memory_format_setup_jp_jsonl() {
  local cfg="$HOME/.vibe-kit/config.json"
  mkdir -p "$HOME/.vibe-kit"
  [ -f "$cfg" ] || echo "{}" > "$cfg"

  echo ""
  _info "Configuring jp-jsonl memory format."
  echo "/vibe-wrap will write handoffs in two forms:"
  echo "  - Markdown prose to <memory_dir>/sessions/<peer>/<session-id>-<date>.md"
  echo "  - JSONL deltas appended to <memory_dir>/{decisions,commitments,follow-ups}.jsonl"
  echo ""

  # 1. memory_dir
  local default_md="$HOME/workspace/memory"
  local md_prompt="$default_md"
  [ -d "$default_md" ] || md_prompt="(no default — type the path)"
  printf "memory_dir [%s]: " "$md_prompt" >&2
  local memory_dir
  read -r memory_dir
  [ -z "$memory_dir" ] && memory_dir="$default_md"
  # Expand ~
  memory_dir="${memory_dir/#\~/$HOME}"
  if [ ! -d "$memory_dir" ]; then
    _warn "memory_dir does not exist: $memory_dir"
    printf "Create it? [y/N]: " >&2
    local create
    read -r create
    case "$create" in
      y|Y|yes|Yes) mkdir -p "$memory_dir" || _die "Failed to create $memory_dir" ;;
      *) _die "memory_dir must exist. Re-run when ready." ;;
    esac
  fi

  # 2. operator_name
  local default_op
  default_op="$(git config --global user.name 2>/dev/null || echo '')"
  printf "operator_name [%s]: " "${default_op:-(required)}" >&2
  local operator_name
  read -r operator_name
  [ -z "$operator_name" ] && operator_name="$default_op"
  [ -z "$operator_name" ] && _die "operator_name required. Set git config user.name first or pass it interactively."

  # 3. confidential_paths (default list, user can extend)
  local default_paths='["credentials/", "vault/", ".env*", "*.key", "*.pem", ".confidential/"]'
  printf "confidential_paths (comma-separated, blank for defaults): " >&2
  local cp_input
  read -r cp_input
  local confidential_paths
  if [ -z "$cp_input" ]; then
    confidential_paths="$default_paths"
  else
    confidential_paths=$(echo "$cp_input" | jq -Rc 'split(",") | map(gsub("^[[:space:]]+|[[:space:]]+$"; ""))')
  fi

  # Write config
  local tmp; tmp="$(mktemp)"
  jq --arg md "$memory_dir" \
     --arg op "$operator_name" \
     --argjson cp "$confidential_paths" \
     '. + {memory_format: "jp-jsonl", memory_dir: $md, operator_name: $op, confidential_paths: $cp}' \
     "$cfg" > "$tmp" && mv "$tmp" "$cfg"

  echo ""
  _ok "memory_format = jp-jsonl"
  _info "Config written to $cfg:"
  jq '{memory_format, memory_dir, operator_name, confidential_paths}' "$cfg"
  echo ""
  _info "Active in next /vibe-wrap invocation."
  _info "Revert with: vibe-retrofit memory-format set vibe-kit-markdown"
}

# ────────────────────────────────────────────────────────────────────────────
# cmd: bug-report (v0.8.0)
# Closes the feedback loop on vibe-kit bugs. /vibe-bug skill writes a JSON
# envelope describing the bug; this primitive files it as a GitHub issue
# (if user opted in via bug-report-mode on) OR saves locally for later.
#
# Usage:
#   vibe-retrofit bug-report --json <file>       # File or save the report
#   vibe-retrofit bug-report --stdin             # Read JSON envelope from stdin
#   vibe-retrofit bug-report --list              # List recent local reports
#   vibe-retrofit bug-report --show <ts>         # Show one report
#   vibe-retrofit bug-report --upstream <ts>     # Upload a local report
#   vibe-retrofit bug-report-mode on|off|status  # Toggle auto-file (default off)
# ────────────────────────────────────────────────────────────────────────────

_bug_report_dir() {
  echo "$HOME/.vibe-kit/bug-reports"
}

_bug_report_recent_log() {
  echo "$(_bug_report_dir)/.recent.jsonl"
}

# Read mode (off by default). Honored at file-time.
_bug_report_mode() {
  local cfg="$HOME/.vibe-kit/config.json"
  if [ -f "$cfg" ]; then
    local m
    m=$(jq -r '.bug_report_mode // "off"' "$cfg" 2>/dev/null)
    [ "$m" = "null" ] && m="off"
    echo "$m"
  else
    echo "off"
  fi
}

# Aggressive redaction: $HOME → ~, strip absolute paths, strip git remote
# URLs, strip env var values. Applied to title + body before file.
_bug_report_redact() {
  local text="$1"
  # $HOME → ~
  text="${text//$HOME/~}"
  # Common absolute path prefixes → relative
  text="${text//\/Users\//~/}"
  text="${text//\/home\//~/}"
  # Strip git URLs (https + ssh)
  text=$(echo "$text" | sed -E 's#https://[^[:space:]]+\.git##g; s#git@[^:[:space:]]+:[^[:space:]]+\.git##g')
  echo "$text"
}

# Build the GitHub issue body from a JSON envelope file.
_bug_report_build_body() {
  local envelope="$1"
  local v
  v=$(jq -r '.vibe_kit_version // "?"' "$envelope")
  cat <<EOF
**Reported via /vibe-bug** (vibe-kit $v).

## What happened
$(jq -r '.what_happened // "(missing)"' "$envelope")

## Expected
$(jq -r '.expected // "(missing)"' "$envelope")

## Actual
$(jq -r '.actual // "(missing)"' "$envelope")

## Reproducer
\`\`\`
$(jq -r '.reproducer // "(none)"' "$envelope")
\`\`\`

$(if jq -e '.suggested_fix' "$envelope" >/dev/null 2>&1 && [ "$(jq -r '.suggested_fix' "$envelope")" != "null" ]; then
  echo "## Suggested fix"
  echo ""
  echo "File: \`$(jq -r '.suggested_fix.file' "$envelope")\` (line $(jq -r '.suggested_fix.line // "?"' "$envelope"))"
  echo ""
  echo '```diff'
  jq -r '.suggested_fix.diff // ""' "$envelope"
  echo '```'
  echo ""
fi)

## Environment
- vibe-kit: \`$(jq -r '.vibe_kit_version // "?"' "$envelope")\`
- skill: \`$(jq -r '.skill // "?"' "$envelope")\`
- trigger_class: \`$(jq -r '.trigger_class // "?"' "$envelope")\`
- severity: \`$(jq -r '.severity // "?"' "$envelope")\`
- OS: \`$(jq -r '.env.os // "?"' "$envelope")\`
- shell: \`$(jq -r '.env.shell // "?"' "$envelope")\`

<details>
<summary>Tool transcript tail (last 5 calls, redacted)</summary>

\`\`\`
$(jq -r '.tool_calls_tail // [] | map(tostring) | join("\n---\n")' "$envelope")
\`\`\`

</details>

---

_Fingerprint: \`$(jq -r '.fingerprint // "?"' "$envelope")\`. Auto-filed by /vibe-bug — see [docs/PATTERNS.md](https://github.com/myi1/vibe-kit/blob/main/docs/PATTERNS.md) Pattern 7 (forthcoming)._
EOF
}

cmd_bug_report() {
  local action="file"
  local envelope=""
  local stdin_mode=0
  local target_ts=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --json)      shift; envelope="$1" ;;
      --stdin)     stdin_mode=1 ;;
      --list)      action="list" ;;
      --show)      shift; action="show"; target_ts="$1" ;;
      --upstream)  shift; action="upstream"; target_ts="$1" ;;
      *) _die "Unknown flag for bug-report: $1" ;;
    esac
    shift
  done

  local dir; dir="$(_bug_report_dir)"
  mkdir -p "$dir"

  case "$action" in
    list)
      ls -t "$dir"/*.json 2>/dev/null | head -20 | while read -r f; do
        local ts skill title
        ts=$(basename "$f" .json)
        skill=$(jq -r '.skill // "?"' "$f" 2>/dev/null)
        title=$(jq -r '.title // "?"' "$f" 2>/dev/null)
        printf "  %s  [%s]  %s\n" "$ts" "$skill" "$title"
      done
      ;;
    show)
      [ -f "$dir/$target_ts.json" ] || _die "No report at $dir/$target_ts.json"
      jq . "$dir/$target_ts.json"
      ;;
    upstream)
      [ -f "$dir/$target_ts.json" ] || _die "No report at $dir/$target_ts.json"
      _bug_report_file_to_github "$dir/$target_ts.json"
      ;;
    file)
      # Read envelope
      if [ "$stdin_mode" -eq 1 ]; then
        envelope=$(mktemp)
        cat > "$envelope"
      fi
      [ -f "$envelope" ] || _die "--json <file> or --stdin required"

      # Always save locally first
      local ts
      ts=$(date +%Y%m%dT%H%M%S)
      local local_file="$dir/$ts.json"
      cp "$envelope" "$local_file"

      # Dedup check via fingerprint (7-day window)
      local fp
      fp=$(jq -r '.fingerprint // ""' "$envelope")
      local recent="$(_bug_report_recent_log)"
      if [ -n "$fp" ] && [ -f "$recent" ]; then
        local cutoff
        cutoff=$(( $(date +%s) - 604800 )) # 7 days
        local seen
        seen=$(jq -r --argjson cutoff "$cutoff" --arg fp "$fp" \
          'select(.ts >= $cutoff and .fingerprint == $fp) | .ts' "$recent" 2>/dev/null | tail -1)
        if [ -n "$seen" ]; then
          _info "Bug report saved locally to $local_file (dedup: same fingerprint seen recently, not refiling)"
          return 0
        fi
      fi

      # Record fingerprint
      echo "{\"ts\": $(date +%s), \"fingerprint\": \"$fp\", \"local_file\": \"$local_file\"}" >> "$recent"

      # File or fall back based on mode
      local mode
      mode="$(_bug_report_mode)"
      if [ "$mode" = "on" ]; then
        _bug_report_file_to_github "$local_file"
      else
        _info "Bug report saved locally to $local_file"
        _info "Filing disabled (mode=$mode). To enable auto-filing: vibe-retrofit bug-report-mode on"
        _info "To upload this report manually: vibe-retrofit bug-report --upstream $ts"
      fi
      ;;
  esac
}

# Helper: file a single saved envelope to GitHub via gh CLI or URL fallback.
_bug_report_file_to_github() {
  local envelope="$1"
  local title body
  title=$(jq -r '.title // "Untitled bug report"' "$envelope")
  title="$(_bug_report_redact "$title")"

  local body_raw
  body_raw=$(_bug_report_build_body "$envelope")
  body="$(_bug_report_redact "$body_raw")"

  local severity
  severity=$(jq -r '.severity // "medium"' "$envelope")
  local labels="bug,from-skill-self-report,severity:$severity"

  # gh auth path
  if command -v gh >/dev/null 2>&1 && gh auth status >/dev/null 2>&1; then
    local url
    url=$(gh issue create \
      --repo myi1/vibe-kit \
      --title "$title" \
      --body "$body" \
      --label "$labels" 2>/dev/null) || {
      _warn "gh issue create failed. Falling back to URL."
      _bug_report_emit_url "$title" "$body" "$labels"
      return 0
    }
    _ok "Filed: $url"
  else
    _warn "gh CLI not authed. Falling back to URL."
    _bug_report_emit_url "$title" "$body" "$labels"
  fi
}

# Helper: emit a pre-filled new-issue URL (URL-encoded).
_bug_report_emit_url() {
  local title="$1" body="$2" labels="$3"
  # URL-encode via jq
  local t_enc b_enc l_enc
  t_enc=$(printf '%s' "$title" | jq -sRr @uri)
  b_enc=$(printf '%s' "$body"  | jq -sRr @uri)
  l_enc=$(printf '%s' "$labels" | jq -sRr @uri)
  local url="https://github.com/myi1/vibe-kit/issues/new?title=$t_enc&body=$b_enc&labels=$l_enc"
  echo "$url"
  _info "Open this URL in a browser to file the issue."
}

# ────────────────────────────────────────────────────────────────────────────
# cmd: bug-report-mode (v0.8.0)
# Opt-in toggle for auto-filing bug reports to GitHub. Defaults OFF.
# ────────────────────────────────────────────────────────────────────────────
cmd_bug_report_mode() {
  local action="${1:-status}"
  local cfg="$HOME/.vibe-kit/config.json"
  case "$action" in
    on)
      mkdir -p "$HOME/.vibe-kit"
      [ -f "$cfg" ] || echo "{}" > "$cfg"
      local tmp
      tmp="$(mktemp)"
      jq '. + {bug_report_mode: "on"}' "$cfg" > "$tmp" && mv "$tmp" "$cfg"
      _ok "Bug report mode: ON"
      echo "  /vibe-bug will auto-file to myi1/vibe-kit via gh CLI (or print a fallback URL)."
      echo "  Reports are also saved locally at $(_bug_report_dir)/"
      ;;
    off)
      mkdir -p "$HOME/.vibe-kit"
      [ -f "$cfg" ] || echo "{}" > "$cfg"
      local tmp
      tmp="$(mktemp)"
      jq '. + {bug_report_mode: "off"}' "$cfg" > "$tmp" && mv "$tmp" "$cfg"
      _ok "Bug report mode: OFF (default)"
      echo "  /vibe-bug will save reports locally only at $(_bug_report_dir)/"
      echo "  Upload manually via: vibe-retrofit bug-report --upstream <ts>"
      ;;
    status)
      echo "Bug report mode: $(_bug_report_mode)"
      echo "  Config: $cfg"
      echo "  Local report dir: $(_bug_report_dir)/"
      if command -v gh >/dev/null 2>&1 && gh auth status >/dev/null 2>&1; then
        echo "  gh auth: OK"
      else
        echo "  gh auth: not authenticated (URL fallback will be used)"
      fi
      ;;
    *)
      _die "Usage: vibe-retrofit bug-report-mode {on|off|status}"
      ;;
  esac
}

# ────────────────────────────────────────────────────────────────────────────
# cmd: per-turn-sync (v0.6.0)
# Quick toggle for the v0.6 per-turn nudge hooks. Writes ~/.vibe-kit/config.json
# so it takes effect across all projects without per-repo editing.
#
# Usage:
#   vibe-retrofit per-turn-sync on            Enable globally (default)
#   vibe-retrofit per-turn-sync off           Disable globally
#   vibe-retrofit per-turn-sync status        Show current resolved mode + source
# ────────────────────────────────────────────────────────────────────────────
cmd_per_turn_sync() {
  local action="${1:-status}"
  local cfg="$HOME/.vibe-kit/config.json"

  case "$action" in
    on)
      mkdir -p "$HOME/.vibe-kit"
      [ -f "$cfg" ] || echo "{}" > "$cfg"
      local tmp
      tmp="$(mktemp)"
      jq '. + {per_turn_sync: "on_changes"}' "$cfg" > "$tmp" && mv "$tmp" "$cfg"
      _ok "Per-turn sync nudges: ON (mode: on_changes)"
      echo "  Hooks will fire on next session start."
      ;;
    off)
      mkdir -p "$HOME/.vibe-kit"
      [ -f "$cfg" ] || echo "{}" > "$cfg"
      local tmp
      tmp="$(mktemp)"
      jq '. + {per_turn_sync: "never"}' "$cfg" > "$tmp" && mv "$tmp" "$cfg"
      _ok "Per-turn sync nudges: OFF (mode: never)"
      echo "  PostToolUse + UserPromptSubmit hooks will skip silently."
      echo "  Re-enable: vibe-retrofit per-turn-sync on"
      ;;
    status)
      # Resolve current effective mode (env > global > per-repo > default)
      local mode source=""
      mode="${GBRAIN_PER_TURN_SYNC:-}"
      [ -n "$mode" ] && source="env (\$GBRAIN_PER_TURN_SYNC)"
      if [ -z "$mode" ] && [ -f "$cfg" ]; then
        mode=$(jq -r '.per_turn_sync // ""' "$cfg" 2>/dev/null)
        [ -n "$mode" ] && [ "$mode" != "null" ] && source="global ($cfg)"
      fi
      if [ -z "$mode" ] || [ "$mode" = "null" ]; then
        if [ -f .vibe-kit-version ]; then
          mode=$(jq -r '.per_turn_sync // "on_changes"' .vibe-kit-version 2>/dev/null)
          source="per-repo (.vibe-kit-version) or default"
        else
          mode="on_changes"
          source="built-in default"
        fi
      fi
      echo "Per-turn sync: $mode"
      echo "  Source:  $source"
      echo ""
      echo "Resolution order (highest precedence first):"
      echo "  1. \$GBRAIN_PER_TURN_SYNC=${GBRAIN_PER_TURN_SYNC:-(unset)}"
      if [ -f "$cfg" ]; then
        local g
        g=$(jq -r '.per_turn_sync // "(unset)"' "$cfg" 2>/dev/null)
        echo "  2. $cfg per_turn_sync=$g"
      else
        echo "  2. $cfg (file missing)"
      fi
      if [ -f .vibe-kit-version ]; then
        local r
        r=$(jq -r '.per_turn_sync // "(unset)"' .vibe-kit-version 2>/dev/null)
        echo "  3. .vibe-kit-version per_turn_sync=$r"
      fi
      echo "  4. built-in default: on_changes"
      ;;
    *)
      _die "Usage: vibe-retrofit per-turn-sync {on|off|status}"
      ;;
  esac
}

# ────────────────────────────────────────────────────────────────────────────
# cmd: upgrade (v0.4.0)
# Updates vibe-kit in-place. Touches a last-check timestamp so the SessionStart
# hook can throttle to once-per-24h.
#
# Modes:
#   --check      Read-only. Exits 0 if up-to-date, 1 if outdated.
#   --auto       Skip confirmation. git pull + reinstall directly.
#   --json       Machine-readable output (combined with --check).
#   (default)    Interactive: check + show CHANGELOG diff + confirm + apply.
# ────────────────────────────────────────────────────────────────────────────
cmd_upgrade() {
  local mode="interactive"  # interactive | check | auto
  local as_json=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --check) mode="check" ;;
      --auto)  mode="auto" ;;
      --json)  as_json=1 ;;
      *) _die "Unknown flag for upgrade: $1" ;;
    esac
    shift
  done

  local current="$VIBE_KIT_VERSION"

  # Best-effort fetch — don't crash if offline.
  git -C "$VIBE_KIT_ROOT" fetch --tags --quiet 2>/dev/null || {
    if [ "$mode" = "check" ] && [ "$as_json" -eq 1 ]; then
      jq -n --arg current "$current" \
        '{current: $current, latest: "unknown", outdated: false, error: "fetch_failed"}'
      return 0
    fi
    if [ "$mode" = "check" ]; then
      _warn "Could not reach origin (offline or git issue). Skipping check."
      return 0
    fi
    _die "Could not git fetch from origin. Check network + retry."
  }

  # Latest tag (semver-sorted; `sort -V` is BSD/GNU portable).
  local latest
  latest="$(git -C "$VIBE_KIT_ROOT" tag -l 'v*' | sort -V | tail -1 | sed 's/^v//')"
  [ -z "$latest" ] && latest="unknown"

  # Outdated if latest != current AND latest sorts higher.
  local outdated="false"
  if [ "$latest" != "unknown" ] && [ "$current" != "$latest" ]; then
    local highest
    highest="$(printf '%s\n%s\n' "$current" "$latest" | sort -V | tail -1)"
    [ "$highest" = "$latest" ] && outdated="true"
  fi

  # Touch the timestamp file — used by the SessionStart hook to throttle.
  mkdir -p "$HOME/.vibe-kit"
  date +%s > "$HOME/.vibe-kit/last-version-check" 2>/dev/null || true

  if [ "$as_json" -eq 1 ]; then
    jq -n \
      --arg current "$current" \
      --arg latest "$latest" \
      --argjson outdated "$outdated" \
      '{current: $current, latest: $latest, outdated: $outdated}'
    [ "$outdated" = "true" ] && return 1 || return 0
  fi

  case "$mode" in
    check)
      if [ "$outdated" = "true" ]; then
        _warn "vibe-kit outdated: $current → $latest"
        echo "To upgrade: vibe-retrofit upgrade   (or /vibe-upgrade in a Claude session)" >&2
        return 1
      fi
      _ok "vibe-kit up to date ($current)"
      return 0
      ;;
    auto|interactive)
      if [ "$outdated" = "false" ]; then
        _ok "vibe-kit already at latest ($current)"
        return 0
      fi
      if [ "$mode" = "interactive" ]; then
        echo "" >&2
        _info "vibe-kit upgrade available: $current → $latest"
        echo "" >&2
        echo "Commits since v$current:" >&2
        git -C "$VIBE_KIT_ROOT" log --pretty=format:'  %h %s' "v$current..v$latest" 2>/dev/null | head -15 >&2
        echo "" >&2
        echo "" >&2
        printf "Proceed with upgrade? [Y/n] " >&2
        local reply
        read -r reply
        case "$reply" in
          n|N|no|No) _info "Cancelled."; return 0 ;;
        esac
      fi
      _info "Pulling latest…"
      git -C "$VIBE_KIT_ROOT" pull --ff-only origin main >&2 \
        || _die "git pull --ff-only failed. Uncommitted changes in $VIBE_KIT_ROOT? Commit or stash + retry."
      _info "Re-running install…"
      bash "$VIBE_KIT_ROOT/bin/install.sh" >&2 \
        || _die "install.sh failed. Inspect output and re-run manually."
      local new_version
      new_version="$(cat "$VIBE_KIT_ROOT/VERSION" 2>/dev/null | tr -d '[:space:]')"
      _ok "Upgraded to $new_version"
      ;;
  esac
}

# ────────────────────────────────────────────────────────────────────────────
# cmd: probe-ai-keys (v0.3.0)
# Detects which AI provider API keys are available. Read-only — never echoes
# the key value itself, only the variable name + where it came from.
# ────────────────────────────────────────────────────────────────────────────
cmd_probe_ai_keys() {
  local as_json=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --json) as_json=1 ;;
      *) _die "Unknown flag for probe-ai-keys: $1" ;;
    esac
    shift
  done

  # Providers in Taskmaster-cheapness order (cheaper = higher priority).
  # Format: <name>:<env_var_name>. Used by the skill to pick a default.
  local PROVIDERS="openai:OPENAI_API_KEY anthropic:ANTHROPIC_API_KEY google:GOOGLE_API_KEY perplexity:PERPLEXITY_API_KEY mistral:MISTRAL_API_KEY groq:GROQ_API_KEY xai:XAI_API_KEY cohere:COHERE_API_KEY"

  # Shell rc files to grep for `export VAR=...`. Only the canonical ones —
  # bash + zsh on macOS/Linux. Skip fish, csh, etc. (low signal).
  local RC_FILES="$HOME/.zshrc $HOME/.bashrc $HOME/.bash_profile $HOME/.profile $HOME/.zprofile $HOME/.zshenv"

  local providers_json="[]"
  local recommended=""
  local pair name var source available rc
  for pair in $PROVIDERS; do
    name="${pair%%:*}"
    var="${pair##*:}"
    source="null"
    available="false"

    # Tier 1: env var directly set.
    # Bash 3.2 compat: indirect expansion via eval (no associative arrays).
    local val
    val="$(eval echo "\${$var:-}")"
    if [ -n "$val" ]; then
      source='"env"'
      available="true"
    else
      # Tier 2: shell rc file declares it.
      for rc in $RC_FILES; do
        if [ -f "$rc" ] && [ -r "$rc" ]; then
          if grep -qE "^[[:space:]]*export[[:space:]]+${var}=" "$rc" 2>/dev/null \
             || grep -qE "^[[:space:]]*${var}=" "$rc" 2>/dev/null; then
            source="\"file:${rc/#$HOME/~}\""
            available="true"
            break
          fi
        fi
      done
    fi

    if [ "$available" = "true" ] && [ -z "$recommended" ]; then
      recommended="$name"
    fi

    providers_json="$(jq -c \
      --arg name "$name" \
      --arg var "$var" \
      --argjson source "$source" \
      --argjson available "$available" \
      '. + [{name: $name, key_var: $var, source: $source, available: $available}]' <<< "$providers_json")"
  done

  if [ "$as_json" -eq 1 ]; then
    jq -n \
      --argjson providers "$providers_json" \
      --arg recommended "$recommended" \
      '{providers: $providers, recommended_for_taskmaster: (if $recommended == "" then null else $recommended end)}'
  else
    echo "AI provider keys (probed at env + ${RC_FILES// /, }):"
    echo "$providers_json" | jq -r '.[] | (if .available then "  ✓ " + .name + " (" + .key_var + " in " + (.source | tostring | gsub("\""; "")) + ")" else "  ✗ " + .name + " (" + .key_var + " not set)" end)'
    echo ""
    if [ -n "$recommended" ]; then
      echo "Recommended for Taskmaster: $recommended"
    else
      echo "No keys detected. Set one (e.g. \`export OPENAI_API_KEY=...\` in your shell rc) before Tier 3."
    fi
  fi
}

# ────────────────────────────────────────────────────────────────────────────
# cmd: cluster-todos (v0.3.0)
# Pure data transform over .vibe-kit-discovery.json. Groups raw TODOs into
# clusters the /vibe-retrofit skill walks the user through (keep / drop /
# dedupe per cluster). Replaces the v0.2 "100+ raw TODOs straight to parse-prd
# producing 100+ noisy tasks" anti-pattern.
# ────────────────────────────────────────────────────────────────────────────
cmd_cluster_todos() {
  local as_json=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --json) as_json=1 ;;
      *) _die "Unknown flag for cluster-todos: $1" ;;
    esac
    shift
  done

  local json_path; json_path="$(_report_json_path)"
  [ -f "$json_path" ] || _die "No discovery report at $json_path. Run 'vibe-retrofit discover' first."

  local todos_json
  todos_json="$(jq -c '.todos // []' "$json_path")"
  local todo_count
  todo_count="$(echo "$todos_json" | jq 'length')"
  if [ "$todo_count" = "0" ]; then
    if [ "$as_json" -eq 1 ]; then
      echo '{"clusters": [], "total_todos": 0}'
    else
      echo "No TODOs to cluster."
    fi
    return 0
  fi

  # Cluster by first 2 path segments (or 1 if path has no slash). Within
  # each cluster, also count keyword breakdown (todo/fixme/xxx/hack).
  # Cap to 20 clusters; merge smallest into "other".
  local clusters_json
  clusters_json="$(echo "$todos_json" | jq -c '
    map(
      capture("^(?<path>[^:]+):(?<line>[0-9]+):(?<text>.*)$") as $parsed |
      $parsed
      | .cluster_key = (
          .path | split("/") |
          if length >= 2 then .[0:2] | join("/") else .[0] end
        )
      | .keyword = (
          .text | ascii_upcase |
          if test("FIXME") then "fixme"
          elif test("HACK") then "hack"
          elif test("XXX") then "xxx"
          elif test("TODO") then "todo"
          else "other" end
        )
    )
    | group_by(.cluster_key)
    | map({
        name: .[0].cluster_key,
        count: length,
        keyword_breakdown: (
          map(.keyword) | group_by(.) | map({(.[0]): length}) | add
        ),
        sample_todos: ([.[0:5][] | {file: .path, line: (.line|tonumber), text: .text}]),
        total_files: (map(.path) | unique | length),
        file_list: (map(.path) | unique)
      })
    | sort_by(-.count)
  ')"

  local cluster_count
  cluster_count="$(echo "$clusters_json" | jq 'length')"
  if [ "$cluster_count" -gt 20 ]; then
    clusters_json="$(echo "$clusters_json" | jq '
      .[:19] + [{
        name: "other",
        count: (.[19:] | map(.count) | add),
        keyword_breakdown: (.[19:] | map(.keyword_breakdown // {}) | add),
        sample_todos: (.[19:] | map(.sample_todos[0:1]) | flatten | .[0:5]),
        total_files: (.[19:] | map(.file_list) | flatten | unique | length),
        file_list: (.[19:] | map(.file_list) | flatten | unique)
      }]
    ')"
  fi

  if [ "$as_json" -eq 1 ]; then
    jq -n \
      --argjson clusters "$clusters_json" \
      --argjson total "$todo_count" \
      '{clusters: $clusters, total_todos: $total}'
  else
    echo "Clusters of $todo_count TODOs:"
    echo ""
    echo "$clusters_json" | jq -r '.[] |
      "  • \(.name) — \(.count) TODOs across \(.total_files) files\n      keywords: \(.keyword_breakdown | to_entries | map(.key + ":" + (.value|tostring)) | join(", "))\n      sample: \(.sample_todos[0:2] | map(.file + ":" + (.line|tostring)) | join(", "))\n"'
  fi
}

# ────────────────────────────────────────────────────────────────────────────
# cmd: taskmaster-configure (v0.3.0)
# Sets Taskmaster main/research/fallback models for the chosen provider.
# Fixes the v0.2 "Taskmaster defaults to Anthropic" pain. Idempotent.
# ────────────────────────────────────────────────────────────────────────────
cmd_taskmaster_configure() {
  local provider="" main="" research="" fallback="" dry_run=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --provider) shift; provider="$1" ;;
      --main)     shift; main="$1" ;;
      --research) shift; research="$1" ;;
      --fallback) shift; fallback="$1" ;;
      --dry-run)  dry_run=1 ;;
      *) _die "Unknown flag for taskmaster-configure: $1" ;;
    esac
    shift
  done

  [ -z "$provider" ] && _die "--provider is required (e.g. openai, anthropic, google, perplexity, mistral)"
  _check_command task-master

  # Per-provider sane defaults — cheap models for bulk PRD parsing.
  case "$provider" in
    openai)
      [ -z "$main" ]     && main="gpt-4o-mini"
      [ -z "$research" ] && research="gpt-4o-mini"
      [ -z "$fallback" ] && fallback="gpt-4o-mini"
      ;;
    anthropic)
      [ -z "$main" ]     && main="claude-haiku-4-5-20251001"
      [ -z "$research" ] && research="claude-haiku-4-5-20251001"
      [ -z "$fallback" ] && fallback="claude-haiku-4-5-20251001"
      ;;
    google)
      [ -z "$main" ]     && main="gemini-1.5-flash"
      [ -z "$research" ] && research="gemini-1.5-flash"
      [ -z "$fallback" ] && fallback="gemini-1.5-flash"
      ;;
    perplexity)
      [ -z "$main" ]     && main="sonar-medium-online"
      [ -z "$research" ] && research="sonar-medium-online"
      [ -z "$fallback" ] && fallback="sonar-medium-online"
      ;;
    mistral|groq|xai|cohere)
      [ -z "$main" ] && _die "No baked-in default model for provider '$provider'. Pass --main <model> explicitly."
      [ -z "$research" ] && research="$main"
      [ -z "$fallback" ] && fallback="$main"
      ;;
    *)
      _die "Unknown provider '$provider'. Supported: openai, anthropic, google, perplexity, mistral, groq, xai, cohere."
      ;;
  esac

  if [ "$dry_run" -eq 1 ]; then
    _info "DRY RUN: would run:"
    _info "  task-master models --setMain $main"
    _info "  task-master models --setResearch $research"
    _info "  task-master models --setFallback $fallback"
    return 0
  fi

  _info "Configuring Taskmaster for $provider (main=$main, research=$research, fallback=$fallback)…"
  # Some task-master versions use --setMain (camelCase), others --set-main.
  # Try camelCase first; if it fails, fall back. Stderr captured so we can
  # detect the "Unknown option" failure mode without it leaking to the user.
  local tm_err
  tm_err="$(task-master models --setMain "$main" 2>&1)" || {
    if echo "$tm_err" | grep -qE 'unknown option|unrecognized'; then
      _info "  (CLI uses kebab-case; falling back to --set-main)"
      task-master models --set-main "$main" >&2 || _die "task-master models --set-main failed"
      task-master models --set-research "$research" >&2 || _die "task-master models --set-research failed"
      task-master models --set-fallback "$fallback" >&2 || _die "task-master models --set-fallback failed"
    else
      _die "task-master models --setMain failed: $tm_err"
    fi
  }
  # camelCase path: complete the other two roles.
  if [ -z "${tm_err##*setMain*}" ] || ! echo "$tm_err" | grep -qE 'unknown option|unrecognized'; then
    task-master models --setResearch "$research" >/dev/null 2>&1 || task-master models --set-research "$research" >&2 || true
    task-master models --setFallback "$fallback" >/dev/null 2>&1 || task-master models --set-fallback "$fallback" >&2 || true
  fi
  _ok "Taskmaster configured for $provider."
}

# ────────────────────────────────────────────────────────────────────────────
# cmd: taskmaster-parse-prd (v0.3.0)
# Wraps `task-master init` (idempotent) + `task-master parse-prd --input=<file>`.
# The skill writes a CURATED PRD (from cluster-todos walkthrough) and hands
# the path here, rather than dumping raw TODOs.
# ────────────────────────────────────────────────────────────────────────────
cmd_taskmaster_parse_prd() {
  local prd="" num_tasks="" force=0 dry_run=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --prd)       shift; prd="$1" ;;
      --num-tasks) shift; num_tasks="$1" ;;
      --force)     force=1 ;;
      --dry-run)   dry_run=1 ;;
      *) _die "Unknown flag for taskmaster-parse-prd: $1" ;;
    esac
    shift
  done

  [ -z "$prd" ] && _die "--prd <file> is required (path to the curated PRD)"
  [ -f "$prd" ] || _die "PRD file not found: $prd"
  _check_command task-master

  if [ "$dry_run" -eq 1 ]; then
    _info "DRY RUN: would init Taskmaster if needed and parse-prd $prd"
    _info "PRD preview (first 20 lines):"
    head -20 "$prd"
    return 0
  fi

  if [ ! -d .taskmaster ]; then
    _info "Initializing Taskmaster…"
    task-master init -y >&2 || _die "task-master init failed"
  fi

  local args=(parse-prd "--input=$prd")
  [ -n "$num_tasks" ] && args+=("--num-tasks=$num_tasks")
  [ "$force" -eq 1 ] && args+=(--force)

  _info "Running: task-master ${args[*]}"
  task-master "${args[@]}" >&2 || _die "task-master parse-prd failed"
  _ok "Taskmaster imported tasks from $(basename "$prd"). Run \`task-master list\` to inspect."
}

# ────────────────────────────────────────────────────────────────────────────
# cmd: rollback
# Combines git revert + cleanup of out-of-commit state (.taskmaster/, docs/vibe-kit/)
# ────────────────────────────────────────────────────────────────────────────
cmd_rollback() {
  local dry_run=0 commit_sha=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --dry-run) dry_run=1 ;;
      --commit)  shift; commit_sha="$1" ;;
      *) _die "Unknown flag for rollback: $1" ;;
    esac
    shift
  done

  _check_git_repo

  # Find the most recent vibe-kit-retrofit commit if not specified
  if [ -z "$commit_sha" ]; then
    commit_sha="$(git log --format='%H' --grep='vibe-kit-retrofit' -n 1 2>/dev/null || true)"
    [ -z "$commit_sha" ] && commit_sha="$(git log --format='%H' --grep='vibe-retrofit' -n 1 2>/dev/null || true)"
  fi

  local will_revert_msg=""
  if [ -n "$commit_sha" ]; then
    will_revert_msg="$(git log --format='%h %s' -n 1 "$commit_sha")"
  fi

  if [ "$dry_run" -eq 1 ]; then
    _info "DRY RUN: rollback plan:"
    [ -n "$commit_sha" ] && _info "  → git revert $commit_sha   ($will_revert_msg)" || _warn "  → no vibe-retrofit commit found to revert"
    [ -d .taskmaster ] && _info "  → rm -rf .taskmaster/   (created outside the revert commit)"
    [ -d docs/vibe-kit ] && _info "  → rm -rf docs/vibe-kit/ (created outside the revert commit, if it was)"
    [ -f .vibe-kit-discovery.md ] && _info "  → rm .vibe-kit-discovery.md"
    [ -f .vibe-kit-discovery.json ] && _info "  → rm .vibe-kit-discovery.json"
    [ -f .vibe-kit-classification.json ] && _info "  → rm .vibe-kit-classification.json"
    return 0
  fi

  if [ -n "$commit_sha" ]; then
    _info "Reverting $will_revert_msg…"
    git revert --no-edit "$commit_sha" >&2
    _ok "Revert committed."
  else
    _warn "No vibe-retrofit commit found. Skipping git revert."
  fi

  if [ -d .taskmaster ]; then
    _info "Removing .taskmaster/ (created outside the retrofit commit)…"
    rm -rf .taskmaster
    _ok "Removed .taskmaster/"
  fi
  rm -f .vibe-kit-discovery.md .vibe-kit-discovery.json .vibe-kit-classification.json 2>/dev/null || true
  _ok "Rollback complete."
}

# ────────────────────────────────────────────────────────────────────────────
# cmd: doctor
# Health check on a retrofitted repo. Read-only.
# ────────────────────────────────────────────────────────────────────────────
cmd_doctor() {
  _check_git_repo

  printf "\n%b┌─ vibe-kit doctor ────────────────────────────────────────┐%b\n" "$C_BOLD" "$C_RESET"

  # 1. Is this repo retrofitted?
  local retrofitted="no"
  if [ -f .vibe-kit-version ]; then
    retrofitted="yes"
    local v_ver v_when v_tier
    v_ver="$(jq -r '.vibe_kit_version // "unknown"' .vibe-kit-version 2>/dev/null)"
    v_when="$(jq -r '.retrofitted_at // "unknown"' .vibe-kit-version 2>/dev/null)"
    v_tier="$(jq -r '.tier // "unknown"' .vibe-kit-version 2>/dev/null)"
    printf "  %b✓%b retrofitted (vibe-kit %s, tier %s, %s)\n" "$C_GREEN" "$C_RESET" "$v_ver" "$v_tier" "$v_when"
  else
    printf "  %b✗%b not retrofitted (.vibe-kit-version missing). Run \`vibe-retrofit tier 3\`.\n" "$C_RED" "$C_RESET"
    printf "%b└──────────────────────────────────────────────────────────┘%b\n\n" "$C_BOLD" "$C_RESET"
    return 0
  fi

  # 2. CLAUDE.md block intact?
  if [ -f CLAUDE.md ] && grep -qF "<!-- vibe-kit-retrofit:v0.1 " CLAUDE.md 2>/dev/null; then
    printf "  %b✓%b CLAUDE.md vibe-kit block present\n" "$C_GREEN" "$C_RESET"
  else
    printf "  %b!%b CLAUDE.md vibe-kit block missing — was it deleted?\n" "$C_YELLOW" "$C_RESET"
  fi

  # 3. KNOWN_GOTCHAS.md freshness
  if [ -f KNOWN_GOTCHAS.md ]; then
    local kg_age_days=0
    if [ "$(uname)" = "Darwin" ]; then
      kg_age_days=$(( ($(date +%s) - $(stat -f %m KNOWN_GOTCHAS.md)) / 86400 ))
    else
      kg_age_days=$(( ($(date +%s) - $(stat -c %Y KNOWN_GOTCHAS.md)) / 86400 ))
    fi
    if [ "$kg_age_days" -lt 14 ]; then
      printf "  %b✓%b KNOWN_GOTCHAS.md updated %d days ago\n" "$C_GREEN" "$C_RESET" "$kg_age_days"
    else
      printf "  %b!%b KNOWN_GOTCHAS.md stale (%d days). The verification gate may not be catching things — or you're not logging.\n" "$C_YELLOW" "$C_RESET" "$kg_age_days"
    fi
  else
    printf "  %b!%b KNOWN_GOTCHAS.md missing\n" "$C_YELLOW" "$C_RESET"
  fi

  # 4. Taskmaster activity
  if [ -d .taskmaster ]; then
    local task_count_open=0
    if command -v task-master >/dev/null 2>&1; then
      task_count_open="$(task-master list --status=pending 2>/dev/null | grep -c '^| ' || echo 0)"
    fi
    printf "  %b✓%b Taskmaster initialized (~%s pending tasks)\n" "$C_GREEN" "$C_RESET" "$task_count_open"
  else
    printf "  %b!%b Taskmaster not initialized (Tier 3 retrofit incomplete?)\n" "$C_YELLOW" "$C_RESET"
  fi

  # 5. Recommended actions
  printf "\n  %bRecommended:%b\n" "$C_BOLD" "$C_RESET"
  printf "    - Run \`/retro\` weekly to capture what shipped\n"
  printf "    - Update KNOWN_GOTCHAS.md when the verification gate catches anything\n"
  printf "    - Run \`task-master next\` at session start\n"

  printf "%b└──────────────────────────────────────────────────────────┘%b\n\n" "$C_BOLD" "$C_RESET"
}

# ────────────────────────────────────────────────────────────────────────────
# cmd: migrate-to-global (v0.2.0)
# One-shot migration for pre-v0.2 retrofitted repos: moves docs/vibe-kit/reference/
# to the global location ~/.vibe-kit/projects/<key>/reference/ and deletes the
# in-repo copy. Idempotent: skips quietly if already migrated.
# ────────────────────────────────────────────────────────────────────────────
cmd_migrate_to_global() {
  local dry_run=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --dry-run) dry_run=1 ;;
      *) _die "Unknown flag for migrate-to-global: $1" ;;
    esac
    shift
  done

  _check_git_repo

  # Require the repo to actually be retrofitted.
  if [ ! -f .vibe-kit-version ]; then
    _die ".vibe-kit-version missing — this repo isn't retrofitted yet. Run \`vibe-retrofit tier 1\` (or 2/3) instead."
  fi

  local project_key; project_key="$(_resolve_project_key)"
  local global_dir; global_dir="$(_global_project_dir "$project_key")"
  local global_ref="$global_dir/reference"
  local global_ref_display="${global_ref/#$HOME/~}"
  local in_repo_ref="docs/vibe-kit/reference"

  _info "Migration plan for project_key=$project_key:"
  _info "  Source:      $in_repo_ref/  (in-repo, branch-coupled)"
  _info "  Destination: $global_ref_display/  (global, branch-independent)"
  echo ""

  # Detect current state.
  local has_in_repo=0 has_global=0
  [ -d "$in_repo_ref" ] && has_in_repo=1
  [ -d "$global_ref" ] && has_global=1

  if [ "$has_in_repo" -eq 0 ] && [ "$has_global" -eq 1 ]; then
    _ok "Already migrated — global reference dir exists, no in-repo copy. Nothing to do."
    _ok "Verify with: ls $global_ref_display/"
    return 0
  fi

  if [ "$has_in_repo" -eq 0 ] && [ "$has_global" -eq 0 ]; then
    _warn "No reference dir found in either location. Run \`vibe-retrofit tier 2\` to scaffold a fresh one."
    return 0
  fi

  # Reuse uncommitted-change check (same posture as merge-claude-md). Only
  # gates on in-repo paths since the global dir isn't tracked anywhere.
  [ "$dry_run" -eq 0 ] && _check_clean_targets "$in_repo_ref" .vibe-kit-version

  if [ "$dry_run" -eq 1 ]; then
    if [ "$has_in_repo" -eq 1 ]; then
      _info "DRY RUN: would mkdir -p $global_ref_display/"
      _info "DRY RUN: would copy $in_repo_ref/ → $global_ref_display/ (preserves symlinks)"
      _info "DRY RUN: would rm -rf $in_repo_ref/"
      _info "DRY RUN: would re-run \`vibe-retrofit tier 2\` to rebuild the global dir from current discovery + add a pointer at docs/vibe-kit/README.md"
      _info "DRY RUN: would re-render CLAUDE.md block (paths now point at global)"
      _info "DRY RUN: would update .vibe-kit-version (adds project_key + global_reference_dir fields)"
    fi
    return 0
  fi

  # Step 1: ensure global dir exists.
  mkdir -p "$global_dir"

  # Step 2: rebuild the global reference from current discovery rather than
  # copying. The copy approach preserves stale symlinks; the rebuild path
  # walks the current discovery JSON and re-creates everything fresh. This
  # is also what migrating a repo that's been retrofitted for months should
  # produce — the latest snapshot of artifacts, not whatever's on disk.
  if [ ! -f "$(_report_json_path)" ]; then
    _info "Re-running discover to pick up current artifacts…"
    cmd_discover
  fi
  _info "Rebuilding global reference dir from current discovery…"
  _scaffold_gstack_reference

  # Step 3: delete the in-repo reference dir (user picked the aggressive option).
  if [ "$has_in_repo" -eq 1 ]; then
    _info "Removing in-repo $in_repo_ref/ (no longer needed)…"
    rm -rf "$in_repo_ref"
    _ok "Removed $in_repo_ref/"
  fi

  # Step 4: leave a pointer README so users browsing the repo know where
  # the reference layer moved to.
  mkdir -p docs/vibe-kit
  cat > docs/vibe-kit/README.md <<EOF
# vibe-kit project notes — $project_key

The reference layer (gstack learnings, design docs, ceo plans, handoffs,
checkpoints) for this project lives **outside** the repo at:

    $global_ref_display/

This is intentional. v0.1 of vibe-kit put it inside \`docs/vibe-kit/reference/\`,
which broke session continuity whenever a fresh Claude Code session opened on
a branch that hadn't merged the retrofit commit. v0.2.0 moved it to a global
location keyed by \`project_key\` so it's available regardless of git state.

The SessionStart hook (\`~/.claude/hooks/vibe-kit-session-start.sh\`) reads
\`project_key\` from \`.vibe-kit-version\` in the cwd and resolves the bundle
from there.

**To refresh the reference layer** (after new design docs, CEO plans,
learnings, or handoffs land in gstack), run from this repo root:

    vibe-retrofit tier 2

**To inspect the reference layer:**

    ls $global_ref_display/

This file (\`docs/vibe-kit/README.md\`) is the only vibe-kit artifact that
stays in the repo's docs/ tree. Everything else moves with branches as
designed (CLAUDE.md additions, KNOWN_GOTCHAS.md, .taskmaster/, .vibe-kit-version).
EOF
  _ok "Wrote pointer at docs/vibe-kit/README.md"

  # Step 5: re-merge CLAUDE.md so the rendered block points at the global
  # paths (the v0.1 block hardcoded docs/vibe-kit/reference/).
  _info "Re-rendering CLAUDE.md block (paths now point at global)…"
  cmd_merge_claude_md --force

  # Step 6: re-write .vibe-kit-version so it carries project_key + global_reference_dir.
  cmd_write_version --tier "$(jq -r '.tier // 1' .vibe-kit-version 2>/dev/null || echo 1)"

  echo ""
  _ok "Migration to v0.2.0 global layout complete."
  _ok "Reference layer is now at: $global_ref_display/"
  _ok "Open a fresh Claude Code session to verify the briefing reads from the new location."
}

# ────────────────────────────────────────────────────────────────────────────
# cmd: tier (orchestrator for tier 1/2/3 — wraps multiple subcommands)
# ────────────────────────────────────────────────────────────────────────────
cmd_tier() {
  local tier="$1"; shift
  local dry_run=0
  for arg in "$@"; do
    [ "$arg" = "--dry-run" ] && dry_run=1
  done

  case "$tier" in
    1)
      _info "Running Tier 1 retrofit (Minimum)…"
      cmd_discover
      cmd_merge_claude_md "$@"
      cmd_write_version --tier 1 "$@"
      _ok "Tier 1 retrofit complete."
      ;;
    2)
      _info "Running Tier 2 retrofit (Standard)…"
      cmd_discover
      cmd_merge_claude_md "$@"
      # NOTE: docs/vibe-kit/ scaffolds are written by the skill orchestrator
      # (it knows how to pre-fill discovered-doc pointers). The bash library
      # only handles deterministic merges. If skill didn't run, fall back to
      # bare template copy.
      _scaffold_docs_bare "$@"
      _scaffold_gstack_reference "$@"
      cmd_write_version --tier 2 "$@"
      _ok "Tier 2 retrofit complete."
      ;;
    3)
      _info "Running Tier 3 retrofit (Full)…"
      cmd_discover
      cmd_merge_claude_md "$@"
      _scaffold_docs_bare "$@"
      _scaffold_gstack_reference "$@"
      cmd_init_taskmaster "$@"
      cmd_write_version --tier 3 "$@"
      _ok "Tier 3 retrofit complete."
      ;;
    *)
      _die "Unknown tier: $tier. Use 1, 2, or 3."
      ;;
  esac
}

# Helper: build ~/.vibe-kit/projects/<project_key>/reference/ from discovered
# gstack artifacts. v0.2.0 moves this OUT of the repo so it's session-available
# regardless of which branch is checked out.
#
# Creates:
#   ~/.vibe-kit/projects/<key>/reference/README.md         — explains what's here
#   ~/.vibe-kit/projects/<key>/reference/gstack-learnings.md — formatted from learnings.jsonl
#   ~/.vibe-kit/projects/<key>/reference/gstack-designs/    — symlinks to design docs
#   ~/.vibe-kit/projects/<key>/reference/gstack-ceo-plans/  — symlinks to ceo-plans/
#   ~/.vibe-kit/projects/<key>/reference/gstack-handoffs/   — symlinks to handoff notes
#   ~/.vibe-kit/projects/<key>/reference/gstack-checkpoints/ — symlinks to checkpoints/
#
# Symlinks use absolute paths (these are local-machine refs, not portable).
# Skipped silently if no gstack artifacts in discovery JSON.
_scaffold_gstack_reference() {
  local dry_run=0
  for arg in "$@"; do
    [ "$arg" = "--dry-run" ] && dry_run=1
  done

  local json_path; json_path="$(_report_json_path)"
  [ -f "$json_path" ] || return 0

  # Check if there are any gstack artifacts at all
  local has_any
  has_any="$(jq -r '
    if (.gstack.project_dirs | length) == 0 then "no" else "yes" end
  ' "$json_path" 2>/dev/null)"
  if [ "$has_any" != "yes" ]; then
    return 0
  fi

  local project_key; project_key="$(_resolve_project_key)"
  local refdir; refdir="$(_global_reference_dir "$project_key")"
  local refdir_display="${refdir/#$HOME/~}"
  if [ "$dry_run" -eq 1 ]; then
    _info "  → WOULD CREATE: $refdir_display/ (gstack symlinks + learnings.md, global — survives branch switches)"
    return 0
  fi
  mkdir -p "$refdir"

  # ── README explaining the reference layout ──────────────────────────────
  {
    echo "# Reference index — project: $project_key"
    echo ""
    echo "Auto-generated by \`vibe-retrofit tier 2+\` (v$VIBE_KIT_VERSION) from gstack artifacts found at:"
    jq -r '.gstack.project_dirs[] | "- `" + . + "`"' "$json_path" 2>/dev/null
    echo ""
    echo "## Where this lives + why"
    echo ""
    echo "This directory is at \`$refdir_display\` — OUTSIDE the project repo on purpose."
    echo ""
    echo "v0.1 put it inside the repo under \`docs/vibe-kit/reference/\`. That broke session continuity: when a fresh Claude Code session opened on a branch that hadn't merged the retrofit commit, the reference layer was invisible. v0.2.0 moved it to a global location keyed by \`project_key\` so it's available to every session regardless of git state."
    echo ""
    echo "The SessionStart hook reads \`.vibe-kit-version\`'s \`project_key\` field from the cwd to resolve this location, so multiple repos with different keys each get their own bundle."
    echo ""
    echo "## What's here"
    echo ""
    echo "- **\`gstack-learnings.md\`** — flattened, deduped, confidence-sorted view of all \`learnings.jsonl\` entries from gstack sessions on this repo. Read this when starting a new session — it's the institutional knowledge future-you keeps relearning."
    echo "- **\`gstack-designs/\`** — symlinks to design docs (\`*-design-*.md\`) authored via /office-hours."
    echo "- **\`gstack-ceo-plans/\`** — symlinks to CEO plan docs (\`ceo-plans/*.md\`) authored via /plan-ceo-review."
    echo "- **\`gstack-checkpoints/\`** — symlinks to context-save snapshots."
    echo "- **\`gstack-handoffs/\`** — symlinks to handoff notes between sessions."
    echo ""
    echo "## Caveat: symlinks are absolute"
    echo ""
    echo "These symlinks point to absolute paths under \`\$HOME/.gstack/projects/\` on the machine where retrofit was run. They will break on another machine. Re-run \`vibe-retrofit tier 2\` on each machine to regenerate them."
    echo ""
    echo "## Refresh"
    echo ""
    echo "Re-run \`vibe-retrofit tier 2\` (or tier 3) from the repo root to pick up new design docs, ceo plans, learnings, and handoffs."
  } > "$refdir/README.md"

  # ── Format learnings.jsonl into human-readable markdown ──────────────────
  # Find all learnings.jsonl across discovered project dirs, dedup by key,
  # sort by confidence desc, write to gstack-learnings.md.
  local learnings_md="$refdir/gstack-learnings.md"
  {
    echo "# gstack learnings — $(basename "$(pwd)")"
    echo ""
    echo "Auto-generated from gstack \`learnings.jsonl\` entries. Sorted by confidence desc. Deduped by \`key\` (highest-confidence entry wins on collision)."
    echo ""
    echo "Read this at the start of a new session. Each entry is a piece of institutional knowledge — a pattern, pitfall, or convention — that someone (often past-you) wrote down so future agents don't have to relearn it."
    echo ""

    # Collect all entries, dedup by key (keep highest confidence), sort by confidence desc.
    # NOTE: bash `set -e` semantics: the loop body MUST always exit 0, otherwise
    # the loop's exit status (= last iteration's exit status) becomes non-zero
    # and set -e silently kills the function mid-stride. The canary surfaced
    # this when the legacy `remax-hub-portal/` slug dir lacked learnings.jsonl
    # — `[ -f x ] && cat ...` exited 1 on that iteration, killed the script,
    # and the entire function aborted with no error message. Use an explicit
    # `if` so the body always exits 0.
    local _tmp_jsonl; _tmp_jsonl="$(mktemp)"
    jq -r '.gstack.project_dirs[]' "$json_path" 2>/dev/null | while IFS= read -r pd; do
      if [ -f "$pd/learnings.jsonl" ]; then
        cat "$pd/learnings.jsonl" >> "$_tmp_jsonl"
      fi
    done

    if [ -s "$_tmp_jsonl" ]; then
      # Sort by confidence desc, dedup by key (jq does this in two passes).
      # NOTE: -r is critical here. Without it, jq prints each constructed string
      # as a JSON-quoted value (with literal \n escapes) instead of as raw text
      # with real newlines. The output ends up as `"## KEY ... \n\n ..."` on
      # one line per entry — unreadable as markdown.
      jq -sr '
        group_by(.key) | map(sort_by(.confidence // 0) | last) | sort_by(-(.confidence // 0))
        | .[] |
          "## \(.key)  ·  confidence \(.confidence // "?")/10  ·  \(.type // "?")\n\n" +
          "**Skill:** `\(.skill // "?")`  ·  **Source:** \(.source // "?")  ·  **Logged:** \(.ts // "?")\n\n" +
          "\(.insight // "(no insight text)")\n\n" +
          (if (.files // []) | length > 0 then "**Files:** " + ((.files // []) | map("`\(.)`") | join(", ")) + "\n\n" else "" end) +
          "---\n"
      ' "$_tmp_jsonl" 2>/dev/null || echo "_(failed to parse learnings.jsonl — file may be malformed)_"
    else
      echo "_No learnings entries found. The first \`/learn\` invocation will create one._"
    fi
    rm -f "$_tmp_jsonl"
  } > "$learnings_md"
  _ok "  → wrote $learnings_md"

  # ── Symlink design / ceo-plans / checkpoints / handoffs ─────────────────
  local subname jq_field
  for pair in "gstack-designs:designs" \
              "gstack-ceo-plans:ceo_plans" \
              "gstack-checkpoints:checkpoints" \
              "gstack-handoffs:handoffs" \
              "gstack-autoplans:autoplans" \
              "gstack-test-plans:test_plans"; do
    subname="${pair%%:*}"
    jq_field="${pair##*:}"
    # Count entries first
    local count
    count="$(jq -r ".gstack.${jq_field} | length" "$json_path" 2>/dev/null)"
    # NOTE: `[ A ] || [ B ] && continue` evaluates as `( [A] || [B] ) && continue`
    # which under set -e dies when count is non-zero (the success case!) because
    # the compound's exit code is the false `&&` short-circuit. Use explicit if.
    if [ "$count" = "0" ] || [ -z "$count" ]; then
      continue
    fi
    mkdir -p "$refdir/$subname"
    local target name
    jq -r ".gstack.${jq_field}[]" "$json_path" 2>/dev/null | while IFS= read -r target; do
      [ -z "$target" ] && continue
      [ ! -e "$target" ] && continue
      name="$(basename "$target")"
      # Only create symlink if not already there (idempotent)
      if [ ! -L "$refdir/$subname/$name" ] && [ ! -e "$refdir/$subname/$name" ]; then
        ln -s "$target" "$refdir/$subname/$name" 2>/dev/null || true
      fi
    done
    _ok "  → linked $count files into $refdir_display/$subname/"
  done

  _ok "  → global reference dir at $refdir_display (visible to every session via SessionStart hook)"
}

# Helper: scaffold docs/vibe-kit/ from templates (bare — no skill enrichment)
_scaffold_docs_bare() {
  local dry_run=0
  for arg in "$@"; do
    [ "$arg" = "--dry-run" ] && dry_run=1
  done

  local tmpl_dir="$VIBE_KIT_ROOT/templates/docs/vibe-kit"
  local json_path; json_path="$(_report_json_path)"
  local project_name
  project_name="$(basename "$(pwd)")"

  local f basename_f rendered
  for f in "$tmpl_dir"/*.tmpl; do
    basename_f="$(basename "$f" .tmpl)"
    local target="docs/vibe-kit/$basename_f"
    if [ -f "$target" ]; then
      _info "  → $target already exists, skipping"
      continue
    fi
    rendered="$(cat "$f")"
    rendered="${rendered//\{\{project_name\}\}/$project_name}"
    rendered="${rendered//\{\{existing_docs_pointer_block\}\}/}"
    rendered="${rendered//\{\{test_command\}\}/$(jq -r '.commands.test // "(not detected)"' "$json_path" 2>/dev/null)}"
    rendered="${rendered//\{\{test_file_count_block\}\}/}"

    if [ "$dry_run" -eq 1 ]; then
      _info "  → WOULD WRITE: $target"
    else
      mkdir -p docs/vibe-kit
      printf '%s\n' "$rendered" > "$target"
      _ok "  → wrote $target"
    fi
  done

  # KNOWN_GOTCHAS.md at repo root
  local kg_tmpl="$VIBE_KIT_ROOT/templates/KNOWN_GOTCHAS.md.tmpl"
  if [ -f "$kg_tmpl" ] && [ ! -f KNOWN_GOTCHAS.md ]; then
    rendered="$(cat "$kg_tmpl")"
    rendered="${rendered//\{\{project_name\}\}/$project_name}"
    if [ "$dry_run" -eq 1 ]; then
      _info "  → WOULD WRITE: KNOWN_GOTCHAS.md"
    else
      printf '%s\n' "$rendered" > KNOWN_GOTCHAS.md
      _ok "  → wrote KNOWN_GOTCHAS.md"
    fi
  fi
}

# ────────────────────────────────────────────────────────────────────────────
# cmd: version
# ────────────────────────────────────────────────────────────────────────────
cmd_version() {
  echo "vibe-retrofit $VIBE_KIT_VERSION"
  echo "  bash:    $(bash --version | head -1)"
  echo "  root:    $VIBE_KIT_ROOT"
  _resolve_sha256
  echo "  sha256:  $_SHA256_CMD"
}

# ────────────────────────────────────────────────────────────────────────────
# cmd: help
# ────────────────────────────────────────────────────────────────────────────
cmd_help() {
  cat <<EOF
vibe-retrofit — rescue your messy AI-coded repos.

USAGE
  vibe-retrofit <subcommand> [flags]

SUBCOMMANDS
  discover              Scan repo for existing context (agent files, plan docs,
                        TODOs, third-party libs, inferred commands). Writes
                        .vibe-kit-discovery.{md,json}. Read-only.
  merge-claude-md       Append/replace the vibe-kit block in CLAUDE.md.
                        Idempotent: detects existing marker block + refuses to
                        overwrite if the block hash mismatches your last
                        retrofit (i.e., you edited inside it).
  write-version         Write .vibe-kit-version JSON (template hashes + block hash).
  init-taskmaster       Initialize Taskmaster + parse-prd from discovered TODOs.
                        Requires LLM API key (OPENAI_API_KEY recommended).
  rollback              Combine git-revert + cleanup of .taskmaster/ and
                        docs/vibe-kit/. Recovery path for failed retrofits.
  doctor                Health check on a retrofitted repo. Read-only.
  migrate-to-global     One-shot v0.1 → v0.2 migration: moves docs/vibe-kit/reference/
                        out of the repo to ~/.vibe-kit/projects/<key>/reference/ so
                        the SessionStart hook works regardless of which branch is
                        checked out. Idempotent. --dry-run supported.

  upgrade [--check]     Check + apply vibe-kit upgrades. --check exits 0/1
    [--auto] [--json]   without modifying anything. --auto skips confirmation.
                        --json for machine-readable output. Touches
                        ~/.vibe-kit/last-version-check; SessionStart hook
                        throttles to 1/day off this timestamp.
  per-turn-sync         Toggle the v0.6 per-turn auto-update nudges.
    on|off|status       on/off writes ~/.vibe-kit/config.json (global).
                        status shows resolved mode + precedence chain.
                        Per-shell override: export GBRAIN_PER_TURN_SYNC=never
  bug-report            v0.8.0: file a bug report (called by /vibe-bug skill).
    --json <file>       Read envelope, file via gh OR save locally based on
    --stdin             bug-report-mode. Aggressive redaction applied.
    --list              List recent local reports.
    --show <ts>         Show one report.
    --upstream <ts>     Upload a local report to GitHub.
  bug-report-mode       Toggle auto-filing bug reports. DEFAULT: off.
    on|off|status       on = /vibe-bug auto-files via gh CLI (or URL fallback).
                        off = local-only; user uploads manually via --upstream.
  memory-format         v0.7.1: configure /vibe-wrap handoff format.
    set jp-jsonl        Interactive wizard: opt into JP's workspace-wide
                        markdown + JSONL delta format. Writes to
                        ~/.vibe-kit/config.json.
    set vibe-kit-markdown   Revert to default (per-project handoffs).
    status              Show resolved format + precedence chain.
  board                 v0.10.0: read-only kanban over your task surfaces.
    --json [--repo P]   Aggregate Taskmaster + git PRs + commitments + specs
                        into unified board JSON (also feeds /vibe-start).
    [--port N] [--open] Live dashboard via bun serve (default port 4317).
                        --open launches the browser. Read-only, Ctrl-C stops.

  Skill-driven primitives (v0.3.0, called by the /vibe-retrofit SKILL):

  probe-ai-keys [--json]      Detect which AI provider API keys are available
                              (env vars + shell rc files). Recommends a provider
                              for Taskmaster.
  cluster-todos [--json]      Group raw TODOs from discovery into clusters by
                              directory + keyword. The skill walks the user
                              through clusters (keep/drop/dedupe) before writing
                              a curated PRD.
  taskmaster-configure        Set Taskmaster main/research/fallback for a chosen
    --provider <name>         provider with sane cheap-model defaults. Fixes the
    [--main M] [--research M] "Taskmaster defaults to Anthropic" footgun.
    [--fallback M]
  taskmaster-parse-prd        Init Taskmaster (idempotent) and import tasks from
    --prd <file>              the CURATED PRD the skill wrote. Replaces the v0.2
    [--num-tasks N] [--force] "dump 108 raw TODOs at parse-prd" anti-pattern.

  tier 1|2|3 [...]      Orchestrator: runs all subcommands in order for the tier.

  version               Show version + env info.
  help                  This message.

GLOBAL FLAGS
  --dry-run             Print every planned mutation without applying. Supported
                        on all mutating subcommands (merge-claude-md, write-version,
                        init-taskmaster, rollback, tier *).
  --force               Override safety gates (e.g., block-hash mismatch in
                        merge-claude-md). Use with care.

ENV
  REPORT_PATH_OVERRIDE  Override directory for .vibe-kit-discovery.{md,json}.
                        Use for client/contract repos: REPORT_PATH_OVERRIDE=~/.vibe-kit/discovery/<slug>
  OPENAI_API_KEY        Required for Tier 3 (parse-prd via task-master).
  ANTHROPIC_API_KEY     Alternative LLM key.
  PERPLEXITY_API_KEY    Alternative LLM key.
  NO_COLOR              Disable colored output if set.

EXAMPLES
  vibe-retrofit discover                  # Read-only scan, writes reports
  vibe-retrofit tier 1 --dry-run          # Preview Tier 1 changes
  vibe-retrofit tier 3                    # Full retrofit (canary repo)
  vibe-retrofit doctor                    # Periodic health check
  vibe-retrofit rollback --dry-run        # Preview rollback

See https://github.com/myi1/vibe-kit for full docs.
EOF
}

# ────────────────────────────────────────────────────────────────────────────
# Entry point
# ────────────────────────────────────────────────────────────────────────────
main() {
  if [ $# -lt 1 ]; then
    cmd_help
    exit 1
  fi

  local sub="$1"; shift
  case "$sub" in
    discover)         cmd_discover "$@" ;;
    merge-claude-md)  cmd_merge_claude_md "$@" ;;
    write-version)    cmd_write_version "$@" ;;
    init-taskmaster)  cmd_init_taskmaster "$@" ;;
    rollback)               cmd_rollback "$@" ;;
    doctor)                 cmd_doctor "$@" ;;
    migrate-to-global)      cmd_migrate_to_global "$@" ;;
    upgrade)                cmd_upgrade "$@" ;;
    per-turn-sync)          cmd_per_turn_sync "$@" ;;
    bug-report)             cmd_bug_report "$@" ;;
    bug-report-mode)        cmd_bug_report_mode "$@" ;;
    memory-format)          cmd_memory_format "$@" ;;
    board)                  cmd_board "$@" ;;
    probe-ai-keys)          cmd_probe_ai_keys "$@" ;;
    cluster-todos)          cmd_cluster_todos "$@" ;;
    taskmaster-configure)   cmd_taskmaster_configure "$@" ;;
    taskmaster-parse-prd)   cmd_taskmaster_parse_prd "$@" ;;
    tier)
      [ $# -lt 1 ] && _die "tier requires a number: 1, 2, or 3"
      cmd_tier "$@"
      ;;
    version|--version|-v)  cmd_version ;;
    help|--help|-h|"")     cmd_help ;;
    *) _die "Unknown subcommand: $sub. Run 'vibe-retrofit help' for usage." ;;
  esac
}

main "$@"
